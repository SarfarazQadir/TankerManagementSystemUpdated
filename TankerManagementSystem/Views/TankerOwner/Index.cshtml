@model IEnumerable<TankerManagementSystem.Models.TankerOwner>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}


@if (TempData["add_owner_message"] != null)
{
    <script>
        Swal.fire({
            title: '@TempData["add_owner_message"]',
            icon: 'success'
        });
    </script>
}

@if (TempData["edit_owner_message"] != null)
{
    <script>
        Swal.fire({
            title: '@TempData["edit_owner_message"]',
            icon: 'success'
        });
    </script>
}

<section class="section">
    <div class="section-body">

        <a href="@Url.Action("Add", "TankerOwner")" class="btn btn-primary">Add Tanker Owner</a>

        <br /><br />

        <div class="card">
            <div class="card-header">
                <h4>Tanker Owner Details</h4>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-bordered table-hover" id="myTable">
                        <thead>
                            <tr>
                                <th>S.No</th>
                                <th>Id</th>
                                <th>Name</th>
                                <th>Phone</th>
                                <th>CNIC</th>
                                <th>Address</th>
                                <th>Created At</th>
                                <th>Action</th>
                            </tr>
                        </thead>

                        <tbody>
                            @{
                                int serial = 1;
                            }

                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@serial</td>
                                    <td>@item.Id</td>
                                    <td>@item.Name</td>
                                    <td>@item.Phone</td>
                                    <td>@item.CNIC</td>
                                    <td>@item.Address</td>
                                    <td>@item.CreatedAt</td>
                                    <td>
                                        <div class="dropdown">
                                            <a href="#" data-toggle="dropdown" class="btn btn-warning dropdown-toggle">Options</a>
                                            <div class="dropdown-menu">
                                                @*   <a href="@Url.Action("Details", "Products", new { id = item.ProductId })" class="dropdown-item has-icon">
                                                            <i class="fas fa-eye"></i> View Details
                                                        </a> *@
                                                <a href="@Url.Action("Edit", new { id = item.Id })" class="dropdown-item has-icon">
                                                    <i class="far fa-edit"></i> Edit
                                                </a>
                                            </div>
                                        </div>
                                    </td>
                                </tr>

                                serial++;
                            }

                        </tbody>
                    </table>

                </div>
            </div>

        </div>

    </div>
</section>