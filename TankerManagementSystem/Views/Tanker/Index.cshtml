@model IEnumerable<TankerManagementSystem.Models.Tanker>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}

@if (TempData["add_tanker_message"] != null)
{
    <script>
        Swal.fire({ title: '@TempData["add_tanker_message"]', icon: 'success' });
    </script>
}

@if (TempData["edit_tanker_message"] != null)
{
    <script>
        Swal.fire({ title: '@TempData["edit_tanker_message"]', icon: 'success' });
    </script>
}

<section class="section">
    <div class="section-body">
        <a href="@Url.Action("Add")" class="btn btn-primary">Add Tanker</a>

        <br /><br />

        <div class="card">
            <div class="card-header">
                <h4>Tanker List</h4>
            </div>

            <div class="card-body">
                <table class="table table-striped table-bordered table-hover" id="myTable">
                    <thead>
                        <tr>
                            <th>S.No</th>
                            <th>Tanker No</th>
                            <th>Owner</th>
                            <th>Model</th>
                            <th>Capacity</th>
                            <th>Balance (PKR)</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @{
                            int i = 1;
                        }

                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@i</td>
                                <td>@item.TankerNo</td>
                                <td>@item.Owner?.Name</td>
                                <td>@item.Model</td>
                                <td>@item.Capacity</td>

                                <td>
                                    @if (item.CurrentBalance > 0)
                                    {
                                        <span class="badge badge-success">@Math.Floor(item.CurrentBalance) (Profit)</span>
                                    }
                                    else if (item.CurrentBalance < 0)
                                    {
                                        <span class="badge badge-danger">@Math.Floor(Math.Abs(item.CurrentBalance)) (Loss/Due)</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-secondary">0</span>
                                    }
                                </td>

                                <td>
                                    <div class="dropdown">
                                        <a href="#" data-toggle="dropdown" class="btn btn-warning dropdown-toggle">Options</a>
                                        <div class="dropdown-menu">
                                            <a href="@Url.Action("Edit", new { id = item.Id })" class="dropdown-item has-icon">
                                                <i class="far fa-edit"></i> Edit
                                            </a>
                                          @*   <a href="javascript:void(0);" onclick="confirmDelete(@item.Id)" class="dropdown-item has-icon text-danger">
                                                <i class="far fa-trash-alt"></i> Delete
                                            </a> *@
                                        </div>
                                    </div>
                                </td>
                            </tr>

                            i++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>