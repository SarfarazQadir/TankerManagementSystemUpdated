@model TankerManagementSystem.Models.Tanker
@{
    ViewData["Title"] = "Edit";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}

<section class="section">
    <div class="section-body">
        <div class="card">
            <div class="card-header">
                <h4>Edit Tanker</h4>
            </div>
            <div class="card-body">
                <form method="post"
                      asp-action="Edit"
                      onsubmit="return validateTankerEditForm(event)">

                    <input type="hidden" asp-for="Id" />

                    <div class="form-group">
                        <label>
                            Tanker No <span style="color:red;">*</span>
                        </label>
                        <input asp-for="TankerNo"
                               id="TankerNo"
                               class="form-control" />
                    </div>

                    <div class="form-group">
                        <label>
                            Select Owner <span style="color:red;">*</span>
                        </label>
                        <select asp-for="OwnerId"
                                id="OwnerId"
                                class="form-control">
                            <option value="">-- Select Owner --</option>
                            @foreach (var item in ViewBag.Owners)
                            {
                                <option value="@item.Id"
                                        selected="@(item.Id == Model.OwnerId)">
                                    @item.Id - @item.Name
                                </option>
                            }
                        </select>
                    </div>

                    <div class="form-group">
                        <label>
                            Model <span style="color:red;">*</span>
                        </label>
                        <input asp-for="Model"
                               id="Model"
                               class="form-control" />
                    </div>

                    <div class="form-group">
                        <label>
                            Capacity <span style="color:red;">*</span>
                        </label>
                        <input asp-for="Capacity"
                               id="Capacity"
                               class="form-control" />
                    </div>

                    <div class="form-group">
                        <label>
                            Current Balance (PKR)
                            <small class="text-muted">(Use positive value for Profit, negative '-' for Loss/Due)</small>
                        </label>
                        <input asp-for="CurrentBalance"
                               id="CurrentBalance"
                               type="number"
                               step="0.01"
                               class="form-control" />
                    </div>

                    <div class="text-center">
                        <input type="submit"
                               value="Update Tanker"
                               class="btn btn-primary" />
                        <a href="@Url.Action("Index")"
                           class="btn btn-secondary">
                            Back
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<script>
    function validateTankerEditForm(event) {
        let tankerNo = document.getElementById("TankerNo").value.trim();
        let ownerId = document.getElementById("OwnerId").value.trim();
        let model = document.getElementById("Model").value.trim();
        let capacity = document.getElementById("Capacity").value.trim();
        let currentBalance = document.getElementById("CurrentBalance").value.trim(); // Changed ID

        if (tankerNo === "") {
            iziToast.error({
                title: 'Error',
                message: 'Tanker No is required!',
                position: 'bottomRight'
            });
            event.preventDefault();
            return false;
        }

        if (ownerId === "") {
            iziToast.error({
                title: 'Error',
                message: 'Please select Owner!',
                position: 'bottomRight'
            });
            event.preventDefault();
            return false;
        }

        if (model === "") {
            iziToast.error({
                title: 'Error',
                message: 'Model is required!',
                position: 'bottomRight'
            });
            event.preventDefault();
            return false;
        }

        if (capacity === "") {
            iziToast.error({
                title: 'Error',
                message: 'Capacity is required!',
                position: 'bottomRight'
            });
            event.preventDefault();
            return false;
        }

        if (currentBalance !== "" && isNaN(currentBalance)) {
            iziToast.error({
                title: 'Error',
                message: 'Current Balance must be a valid number!',
                position: 'bottomRight'
            });
            event.preventDefault();
            return false;
        }

        return true;
    }
</script>