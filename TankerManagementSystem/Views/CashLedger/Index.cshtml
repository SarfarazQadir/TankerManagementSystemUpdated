@model IEnumerable<TankerManagementSystem.Models.ViewModels.CashLedgerVM>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}

<section class="section">
    <div class="section-body">
        <a href="@Url.Action("AddEntry")" class="btn btn-primary"> Add Cash Entry</a>
        <a href="@Url.Action("DailyReport")" class="btn btn-primary"> Today Report Print</a>
        <a href="@Url.Action("AllReport")" class="btn btn-primary"> All Report Print</a>
        <br />
        <br />
        <div class="card">
            <div class="card-header">
                <h4>Cash Ledger List</h4>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-bordered table-hover" id="myTable">
                        <thead>
                            <tr>
                                <th>S.No</th>
                                <th>Date</th>
                                <th>Description</th>
                                <th>Credit</th>
                                <th>Debit</th>
                                <th>Balance</th>
                                <th>Created By</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int i = 1;
                            }
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@i</td>
                                    <td>
                                        @item.EntryDate.ToString("dd MMM yyyy")
                                    </td>
                                    <td>@item.Description</td>
                                    <td style="color:green">@Math.Floor(item.Credit)</td>
                                    <td style="color:red">@Math.Floor(item.Debit)</td>
                                    <td>@Math.Floor(item.Balance)</td>
                                    <td>@item.CreatedByName</td>
                                    <td>
                                        <div class="dropdown">
                                            <button class="btn btn-warning dropdown-toggle"
                                                    data-toggle="dropdown">
                                                Options
                                            </button>
                                            <div class="dropdown-menu">
                                                <a class="dropdown-item"
                                                   href="@Url.Action("EditEntry", new { id = item.Id })">
                                                    Edit
                                                </a>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                                i++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>