
@{
    ViewData["Title"] = "Add";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}


<section class="section">
    <div class="section-body">
        <div class="card">
            <div class="card-header">
                <h4>Add Commission</h4>
            </div>

            <div class="card-body">
                <form method="post" asp-action="Add">

                    <div class="form-group">
                        <label>Name</label>
                        <input type="text" name="Name" class="form-control" placeholder="Enter Commission Name" />
                    </div>

                    <div class="form-group">
                        <label>Percentage (%)</label>
                        <input type="number" step="0.01" name="Percentage" class="form-control" />
                    </div>

                    <div class="form-group">
                        <label>Is Active</label>
                        <select name="IsActive" class="form-control">
                            <option value="true">Active</option>
                            <option value="false">Inactive</option>
                        </select>
                    </div>

                    <div class="text-center">
                        <input type="submit" value="Add Commission" class="btn btn-primary" />
                        <a href="@Url.Action("Index")" class="btn btn-secondary">Back</a>
                    </div>

                </form>
            </div>
        </div>
    </div>
</section>