@model IEnumerable<TankerManagementSystem.Models.CommissionSetup>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}


@if (TempData["add_commission_message"] != null)
{
    <script>
        Swal.fire({ title: '@TempData["add_commission_message"]', icon: 'success' });
    </script>
}

@if (TempData["edit_commission_message"] != null)
{
    <script>
        Swal.fire({ title: '@TempData["edit_commission_message"]', icon: 'success' });
    </script>
}

<section class="section">
    <div class="section-body">
        @* <a href="@Url.Action("Add")" class="btn btn-primary">Add Commission</a> *@
        @if (!Model.Any())
        {
            <a href="@Url.Action("Add")" class="btn btn-primary">
                Add Commission
            </a>
        }
        <br /><br />

        <div class="card">
            <div class="card-header">
                <h4>Commission List</h4>
            </div>

            <div class="card-body">
                <table class="table table-striped table-bordered table-hover" id="myTable">
                    <thead>
                        <tr>
                            <th>S.No</th>
                            <th>Name</th>
                            <th>Percentage</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @{
                            int i = 1;
                        }

                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@i</td>
                                <td>@item.Name</td>
                                <td>@Math.Floor(item.Percentage)%</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge badge-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-danger">Inactive</span>
                                    }
                                </td>

                                <td>
                                    <div class="dropdown">
                                        <a href="#" data-toggle="dropdown" class="btn btn-warning dropdown-toggle">Options</a>
                                        <div class="dropdown-menu">
                                            @*   <a href="@Url.Action("Details", "Products", new { id = item.ProductId })" class="dropdown-item has-icon">
                                                            <i class="fas fa-eye"></i> View Details
                                                        </a> *@
                                            <a href="@Url.Action("Edit", new { id = item.Id })" class="dropdown-item has-icon">
                                                <i class="far fa-edit"></i> Edit
                                            </a>
                                        </div>
                                    </div>
                                </td>
                            </tr>

                            i++;
                        }

                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>