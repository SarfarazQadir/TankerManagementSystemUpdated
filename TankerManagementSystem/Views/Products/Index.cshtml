@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}
@{
    if (TempData["add_product_message"] != null)
    {
        <script>
            Swal.fire({
            title: '@TempData["add_product_message"]',
            text: 'Clicked the button!',
            icon: 'success'
            });
        </script>

    }
    if (TempData["edit_product_message"] != null)
    {
        <script>
            Swal.fire({
            title: '@TempData["edit_product_message"]',
            text: 'Clicked the button!',
            icon: 'success'
            });
        </script>

    }
    if (TempData["delete_product_message"] != null)
    {
        <script>
            Swal.fire({
            title: '@TempData["delete_product_message"]',
            text: 'Clicked the button!',
            icon: 'success'
            });
        </script>

    }
}

<section class="section">
    <div class="section-body">
        <a href="@Url.Action("Add", "Products")" class="btn btn-primary align-right">Add Product</a>
        <br /><br />
        <div class="card">
            <div class="card-header">
                <h4>Product Details</h4>
            </div>
            <div class="card-body">
                <div class="table-responsive">

                    <table class="table table-striped table-bordered table-hover" id="myTable">
                        <thead>
                            <tr>
                                <th>S.No</th>
                                <th>Id</th>
                                <th>Name</th>
                                <th>Description</th>
                                <th>CreatedAt</th>
                                <th>CreatedBy</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int serialNumber = 1;
                            }
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@serialNumber</td>
                                    <td>@item.Id</td>
                                    <td>@item.ProductName</td>
                                    <td>@item.Description</td>
                                    <td>@item.CreatedAt.ToString("dd/MMM/yyy hh:tt")</td>
                                    <td>@item.CreatedBy</td>
                                    <td>
                                        <div class="dropdown">
                                            <a href="#" data-toggle="dropdown" class="btn btn-warning dropdown-toggle">Options</a>
                                            <div class="dropdown-menu">
                                                @*   <a href="@Url.Action("Details", "Products", new { id = item.ProductId })" class="dropdown-item has-icon">
                                                            <i class="fas fa-eye"></i> View Details
                                                        </a> *@
                                                <a href="@Url.Action("Edit", "Products", new { id = item.Id })" class="dropdown-item has-icon">
                                                    <i class="far fa-edit"></i> Edit
                                                </a>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                                serialNumber++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>


