
@{
    ViewData["Title"] = "Add";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}

<section class="section">
    <div class="section-body">
        <div class="row">
            <div class="col-12 col-md-6 col-lg-12">
                <div class="card">
                    <div class="card-header">
                        <h4>Add Product</h4>
                    </div>
                    <div class="card-body">
                        <form id="addProductForm" method="post" asp-action="Add" onsubmit="return validateProductForm(event)">
                            <div class="form-group row">
                                <label for="ProductName" class="col-sm-3 col-form-label">Product Name<span style="color:red;">*</span></label>
                                <div class="col-sm-9">
                                    <input type="text" name="ProductName" class="form-control" id="ProductName" placeholder="Enter Product Name">
                                </div>
                            </div>
                            <div class="form-group row">
                                <label for="Description" class="col-sm-3 col-form-label">Product Description<span style="color:red;">*</span></label>
                                <div class="col-sm-9">
                                    <input type="text" name="Description" class="form-control" id="Description" placeholder="Enter Product Description">
                                </div>
                            </div>
                            <div class="card-footer text-center">
                                <input type="submit" value="Add Product" class="btn btn-primary" />
                                <a href="@Url.Action("Index")" class="btn btn-secondary">Back</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<script>
    function validateProductForm(event) {

        let productName = document.getElementById("ProductName").value.trim();
        let description = document.getElementById("Description").value.trim();

        if (productName === "") {
            iziToast.error({
                title: 'Error',
                message: 'Product Name is required!',
                position: 'bottomRight'
            });

            event.preventDefault();
            return false;
        }

        if (description === "") {
            iziToast.error({
                title: 'Error',
                message: 'Description is required!',
                position: 'bottomRight'
            });

            event.preventDefault();
            return false;
        }

        return true;
    }
</script>