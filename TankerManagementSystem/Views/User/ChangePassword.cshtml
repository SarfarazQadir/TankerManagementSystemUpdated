@model TankerManagementSystem.Models.ViewModels.ChangePasswordAdminVM

@{
    ViewData["Title"] = "Change User Password";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}

<style>
    /* Base Back Button Styling */
    .btn-outline-back {
        border: 1px solid #86608E;
        color: #86608E;
        background-color: transparent;
    }

        .btn-outline-back:hover {
            background-color: #f5f0f6;
            color: #6a4772;
            border-color: #6a4772;
        }

    /* Core Submit Button Hover Action */
    .btn-theme-submit:hover {
        background-color: #6a4772 !important;
        box-shadow: 0 4px 16px rgba(106, 71, 114, 0.35) !important;
    }

    /* Input Focus Theme integration */
    .form-control:focus {
        border-color: #86608E !important;
        box-shadow: 0 0 0 0.2.5rem rgba(134, 96, 142, 0.15) !important;
    }

    /* 🔥 Eye Icon Toggle Premium Core */
    .password-toggle-btn {
        background-color: #ffffff;
        border-color: #e2d9e6;
        border-left: none;
        border-radius: 0 8px 8px 0;
        color: #a392a8;
        cursor: pointer;
        transition: color 0.2s ease;
    }

        .password-toggle-btn:hover {
            color: #86608E;
        }

    .gap-2 > * + * {
        margin-left: 10px;
    }
</style>

<section class="section" style="background-color: #fcfbfe; min-height: 85vh; padding: 20px 0;">
    <div class="section-body container-fluid">

        <!-- Header Section -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 style="font-weight: 700; color: #2e1f33; font-size: 1.5rem; margin-bottom: 4px;">Reset Password</h2>
                <p class="text-muted" style="font-size: 0.875rem; margin: 0;">Update account authentication credentials securely.</p>
            </div>
            <div>
                <a href="@Url.Action("FetchUsers")" class="btn btn-outline-back" style="border-radius: 8px; font-weight: 500; font-size: 0.875rem; padding: 8px 16px; transition: all 0.2s;">
                    <i data-feather="arrow-left" style="width: 16px; height: 16px; margin-right: 6px; vertical-align: text-bottom;"></i> Back to List
                </a>
            </div>
        </div>

        <!-- Notification Alerts -->
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger border-0 shadow-sm d-flex align-items-center mb-4" style="border-radius: 8px; font-size: 0.9rem; background-color: #fdf2f8; color: #86198f;">
                <i data-feather="alert-circle" style="width: 20px; height: 20px; margin-right: 10px;"></i>
                <div>@TempData["Error"]</div>
            </div>
        }

        <div class="row justify-content-center">
            <div class="col-xl-6 col-lg-8 col-md-10">

                <form method="post" asp-action="ChangePassword">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="UserId" />
                    <input type="hidden" asp-for="Username" />
                    <input type="hidden" asp-for="Email" />

                    <!-- Main Card Wrapper -->
                    <div class="card border-0 shadow-sm" style="border-radius: 12px; background: #ffffff;">
                        <div class="card-body p-4">

                            <!-- Card Section Heading -->
                            <div class="d-flex align-items-center mb-3">
                                <div style="background-color: #f5f0f6; padding: 10px; border-radius: 8px; margin-right: 12px; color: #86608E;">
                                    <i data-feather="key" style="width: 20px; height: 20px;"></i>
                                </div>
                                <h5 style="font-weight: 600; color: #4a3552; margin: 0; font-size: 1.1rem;">Credentials for @Model.Username</h5>
                            </div>
                            <hr style="border-color: #f5f0f6; margin-bottom: 24px;" />

                            <!-- Readonly Email Metadata View -->
                            <div class="form-group mb-4">
                                <label style="font-weight: 500; color: #6b5873; font-size: 0.85rem; margin-bottom: 6px;">Target User Email</label>
                                <div class="input-group">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text" style="background-color: #fcfaff; border-color: #e2d9e6; border-right: none; border-radius: 8px 0 0 8px; color: #a392a8;">
                                            <i data-feather="mail" style="width: 14px;"></i>
                                        </span>
                                    </div>
                                    <input readonly type="text" class="form-control" value="@Model.Email" style="background-color: #fcfaff; border-color: #e2d9e6; border-left: none; border-radius: 0 8px 8px 0; color: #7a6982; font-weight: 500; font-size: 0.9rem; height: 42px; cursor: not-allowed;" />
                                </div>
                            </div>

                            <!-- New Password Field with Eye Icon Toggle -->
                            <div class="form-group mb-4">
                                <label asp-for="NewPassword" style="font-weight: 500; color: #6b5873; font-size: 0.85rem; margin-bottom: 6px;">New Password</label>
                                <div class="input-group">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text" style="background-color: #ffffff; border-color: #e2d9e6; border-right: none; border-radius: 8px 0 0 8px; color: #86608E;">
                                            <i data-feather="lock" style="width: 14px;"></i>
                                        </span>
                                    </div>
                                    <input asp-for="NewPassword" type="password" id="txtNewPassword" class="form-control" placeholder="Enter new secure password" style="border-color: #e2d9e6; border-left: none; border-right: none; font-size: 0.9rem; height: 42px;" />
                                    <div class="input-group-append">
                                        <span class="input-group-text password-toggle-btn" onclick="togglePasswordVisibility('txtNewPassword', 'iconNewPassword')">
                                            <i data-feather="eye" id="iconNewPassword" style="width: 16px; height: 16px;"></i>
                                        </span>
                                    </div>
                                </div>
                                <span asp-validation-for="NewPassword" class="text-danger small mt-1 d-block" style="font-weight: 500;"></span>
                            </div>

                            <!-- Confirm Password Field with Eye Icon Toggle -->
                            <div class="form-group mb-3">
                                <label asp-for="ConfirmPassword" style="font-weight: 500; color: #6b5873; font-size: 0.85rem; margin-bottom: 6px;">Confirm New Password</label>
                                <div class="input-group">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text" style="background-color: #ffffff; border-color: #e2d9e6; border-right: none; border-radius: 8px 0 0 8px; color: #86608E;">
                                            <i data-feather="shield" style="width: 14px;"></i>
                                        </span>
                                    </div>
                                    <input asp-for="ConfirmPassword" type="password" id="txtConfirmPassword" class="form-control" placeholder="Re-type new password" style="border-color: #e2d9e6; border-left: none; border-right: none; font-size: 0.9rem; height: 42px;" />
                                    <div class="input-group-append">
                                        <span class="input-group-text password-toggle-btn" onclick="togglePasswordVisibility('txtConfirmPassword', 'iconConfirmPassword')">
                                            <i data-feather="eye" id="iconConfirmPassword" style="width: 16px; height: 16px;"></i>
                                        </span>
                                    </div>
                                </div>
                                <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block" style="font-weight: 500;"></span>
                            </div>

                        </div>
                    </div>

                    <!-- Actions Bar Card -->
                    <div class="card border-0 shadow-sm mt-3" style="border-radius: 12px; background-color: #ffffff;">
                        <div class="card-body py-3 px-4 d-flex justify-content-end align-items-center gap-2">
                            <a asp-action="FetchUsers" class="btn btn-light" style="font-weight: 600; font-size: 0.9rem; padding: 10px 20px; border-radius: 8px; border: 1px solid #e4e6fc;">Cancel</a>
                            <button type="submit" class="btn btn-theme-submit" style="background-color: #86608E; color: #ffffff; font-weight: 600; font-size: 0.9rem; padding: 10px 24px; border-radius: 8px; border: none; box-shadow: 0 4px 12px rgba(134, 96, 142, 0.2); transition: all 0.2s;">
                                <i data-feather="save" style="width: 16px; height: 16px; margin-right: 6px; vertical-align: text-bottom;"></i> Update Password
                            </button>
                        </div>
                    </div>

                </form>

            </div>
        </div>

    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <!-- 🔥 SHOW/HIDE PASSWORD JAVASCRIPT BLOCK -->
    <script>
        function togglePasswordVisibility(inputId, iconId) {
            const passwordInput = document.getElementById(inputId);
            const eyeIcon = document.getElementById(iconId);

            if (passwordInput && eyeIcon) {
                if (passwordInput.type === "password") {
                    passwordInput.type = "text";
                    // Feather icon change dynamically
                    eyeIcon.setAttribute('data-feather', 'eye-off');
                } else {
                    passwordInput.type = "password";
                    eyeIcon.setAttribute('data-feather', 'eye');
                }

                // Re-initialize feather icons so the change shows on UI immediately
                if (typeof feather !== 'undefined') {
                    feather.replace();
                }
            }
        }
    </script>
}