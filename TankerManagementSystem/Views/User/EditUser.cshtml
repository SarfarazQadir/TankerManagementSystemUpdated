@model TankerManagementSystem.Models.ViewModels.UserEditMVCVM

@{
    ViewData["Title"] = "Edit User Settings";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}

<style>
    /* Base Back Button Styling */
    .btn-outline-back {
        border: 1px solid #86608E;
        color: #86608E;
        background-color: transparent;
    }

        .btn-outline-back:hover {
            background-color: #f5f0f6; /* Light theme hover */
            color: #6a4772;
            border-color: #6a4772;
        }

    /* Core Submit Button Hover Action */
    .btn-theme-submit:hover {
        background-color: #6a4772 !important; /* Lighter/Darker cohesive shift for rich UI feedback */
        box-shadow: 0 4px 16px rgba(106, 71, 114, 0.35) !important;
    }

    /* Premium Checkbox Styling matched to branding */
    .custom-checkbox-matrix {
        position: static;
        width: 18px;
        height: 18px;
        cursor: pointer;
        accent-color: #86608E; /* Theme color for active checkbox status */
        border: 2px solid #bfaec4;
        border-radius: 4px;
        transition: transform 0.1s ease;
    }

        .custom-checkbox-matrix:hover {
            transform: scale(1.15);
        }

    /* Custom Switch Accent Integration */
    .custom-control-input:checked ~ .custom-control-label::before {
        background-color: #86608E !important;
        border-color: #86608E !important;
    }

    /* Row highlight tracking */
    .table tbody tr:hover {
        background-color: #faf7fc;
    }

    .gap-2 > * + * {
        margin-left: 10px;
    }
</style>
<section class="section" style="background-color: #fcfbfe; min-height: 85vh; padding: 20px 0;">
    <div class="section-body container-fluid">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 style="font-weight: 700; color: #2e1f33; font-size: 1.5rem; margin-bottom: 4px;">User & Access Control</h2>
                <p class="text-muted" style="font-size: 0.875rem; margin: 0;">Manage identity settings and application module permissions.</p>
            </div>
            <div>
                <a href="@Url.Action("FetchUsers")" class="btn btn-outline-back" style="border-radius: 8px; font-weight: 500; font-size: 0.875rem; padding: 8px 16px; transition: all 0.2s;">
                    <i data-feather="arrow-left" style="width: 16px; height: 16px; margin-right: 6px; vertical-align: text-bottom;"></i> Back to List
                </a>
            </div>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger border-0 shadow-sm d-flex align-items-center" style="border-radius: 8px; font-size: 0.9rem; background-color: #fdf2f8; color: #86198f;">
                <i data-feather="alert-circle" style="width: 20px; height: 20px; margin-right: 10px;"></i>
                <div>@TempData["Error"]</div>
            </div>
        }

        <form method="post" asp-action="EditUser">
            <input type="hidden" asp-for="UserId" />

            <div class="row">

                <div class="col-xl-4 col-lg-5 mb-4">
                    <div class="card border-0 shadow-sm" style="border-radius: 12px; height: 100%; background: #ffffff;">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center mb-3">
                                <div style="background-color: #f5f0f6; padding: 10px; border-radius: 8px; margin-right: 12px; color: #86608E;">
                                    <i data-feather="user" style="width: 20px; height: 20px;"></i>
                                </div>
                                <h5 style="font-weight: 600; color: #4a3552; margin: 0; font-size: 1.1rem;">Identity Options</h5>
                            </div>
                            <hr style="border-color: #f5f0f6; margin-bottom: 24px;" />

                            <div class="form-group mb-4">
                                <label style="font-weight: 500; color: #6b5873; font-size: 0.85rem; margin-bottom: 6px;">Username</label>
                                <div class="input-group">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text" style="background-color: #fcfaff; border-color: #e2d9e6; border-right: none; border-radius: 8px 0 0 8px; color: #a392a8;"><i data-feather="lock" style="width: 14px;"></i></span>
                                    </div>
                                    <input readonly type="text" asp-for="Username" class="form-control" style="background-color: #fcfaff; border-color: #e2d9e6; border-left: none; border-radius: 0 8px 8px 0; color: #7a6982; font-weight: 500; font-size: 0.9rem; height: 42px;" />
                                </div>
                            </div>

                            <div class="form-group mb-4">
                                <label style="font-weight: 500; color: #6b5873; font-size: 0.85rem; margin-bottom: 6px;">Email Address</label>
                                <div class="input-group">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text" style="background-color: #fcfaff; border-color: #e2d9e6; border-right: none; border-radius: 8px 0 0 8px; color: #a392a8;"><i data-feather="mail" style="width: 14px;"></i></span>
                                    </div>
                                    <input readonly type="email" asp-for="Email" class="form-control" style="background-color: #fcfaff; border-color: #e2d9e6; border-left: none; border-radius: 0 8px 8px 0; color: #7a6982; font-weight: 500; font-size: 0.9rem; height: 42px; cursor: not-allowed;" title="Email status is locked and cannot be changed." />
                                </div>
                            </div>

                            <div class="p-3" style="background-color: #fbf9fc; border: 1px solid #f1e9f3; border-radius: 10px; margin-top: 30px;">
                                <div class="custom-control custom-switch d-flex align-items-center justify-content-between p-0">
                                    <div>
                                        <label class="form-check-label" for="editOtp" style="font-weight: 600; color: #5c3f63; font-size: 0.9rem; cursor: pointer; display: block; margin: 0;">Require OTP Login</label>
                                        <span class="text-muted" style="font-size: 0.75rem; display: block; color: #86608E !important; opacity: 0.8;">Enforces secure 2FA authentication</span>
                                    </div>
                                    <div style="position: relative;">
                                        <input type="checkbox" asp-for="EnableOTP" class="custom-control-input" id="editOtp" style="cursor: pointer;" />
                                        <label class="custom-control-label" for="editOtp" style="cursor: pointer; padding-left: 35px;"></label>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>

                <div class="col-xl-8 col-lg-7 mb-4">
                    <div class="card border-0 shadow-sm" style="border-radius: 12px; height: 100%; background: #ffffff;">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center mb-3">
                                <div style="background-color: #f5f0f6; padding: 10px; border-radius: 8px; margin-right: 12px; color: #86608E;">
                                    <i data-feather="shield" style="width: 20px; height: 20px;"></i>
                                </div>
                                <h5 style="font-weight: 600; color: #4a3552; margin: 0; font-size: 1.1rem;">Module Access Rights</h5>
                            </div>
                            <hr style="border-color: #f5f0f6; margin-bottom: 20px;" />

                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0" style="border-collapse: separate; border-spacing: 0 4px;">
                                    <thead>
                                        <tr style="background-color: #f9f6fa;">
                                            <th style="border: none; border-radius: 8px 0 0 8px; color: #5c3f63; font-weight: 600; font-size: 0.85rem; padding: 12px 16px;">Operational Module</th>
                                            <th class="text-center" style="border: none; color: #5c3f63; font-weight: 600; font-size: 0.85rem; padding: 12px;">View</th>
                                            <th class="text-center" style="border: none; color: #5c3f63; font-weight: 600; font-size: 0.85rem; padding: 12px;">Create</th>
                                            <th class="text-center" style="border: none; color: #5c3f63; font-weight: 600; font-size: 0.85rem; padding: 12px;">Edit</th>
                                            <th class="text-center" style="border: none; border-radius: 0 8px 8px 0; color: #5c3f63; font-weight: 600; font-size: 0.85rem; padding: 12px;">Delete</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @for (int i = 0; i < Model.ModulePermissions.Count; i++)
                                        {
                                            <tr style="transition: background-color 0.2s;">
                                                <td style="padding: 16px; border-bottom: 1px solid #fcf9fc; font-weight: 500; color: #3d2a42; font-size: 0.9rem;">
                                                    <input type="hidden" asp-for="@Model.ModulePermissions[i].ModuleId" />
                                                    <input type="hidden" asp-for="@Model.ModulePermissions[i].ModuleName" />

                                                    <div class="d-flex align-items-center">
                                                        <span style="display: inline-block; width: 6px; height: 6px; background-color: #bfaec4; border-radius: 50%; margin-right: 10px;"></span>
                                                        @Model.ModulePermissions[i].ModuleName
                                                    </div>
                                                </td>

                                                <td class="text-center" style="padding: 16px; border-bottom: 1px solid #fcf9fc;">
                                                    <input type="checkbox" asp-for="@Model.ModulePermissions[i].CanView" class="form-check-input custom-checkbox-matrix" />
                                                </td>
                                                <td class="text-center" style="padding: 16px; border-bottom: 1px solid #fcf9fc;">
                                                    <input type="checkbox" asp-for="@Model.ModulePermissions[i].CanCreate" class="form-check-input custom-checkbox-matrix" />
                                                </td>
                                                <td class="text-center" style="padding: 16px; border-bottom: 1px solid #fcf9fc;">
                                                    <input type="checkbox" asp-for="@Model.ModulePermissions[i].CanEdit" class="form-check-input custom-checkbox-matrix" />
                                                </td>
                                                <td class="text-center" style="padding: 16px; border-bottom: 1px solid #fcf9fc;">
                                                    <input type="checkbox" asp-for="@Model.ModulePermissions[i].CanDelete" class="form-check-input custom-checkbox-matrix" />
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <div class="card border-0 shadow-sm mt-3" style="border-radius: 12px; background-color: #ffffff;">
                <div class="card-body py-3 px-4 d-flex justify-content-end align-items-center gap-2">
                    <button type="submit" class="btn btn-theme-submit" style="background-color: #86608E; color: #ffffff; font-weight: 600; font-size: 0.9rem; padding: 10px 24px; border-radius: 8px; border: none; box-shadow: 0 4px 12px rgba(134, 96, 142, 0.2); transition: all 0.2s;">
                        <i data-feather="check" style="width: 16px; height: 16px; margin-right: 6px; vertical-align: text-bottom;"></i> Save System Changes
                    </button>
                </div>
            </div>

        </form>

    </div>
</section>
