@model IEnumerable<TankerManagementSystem.Models.PersonalKhata>

@{
    ViewData["Title"] = "Customer Credit Account";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}

<section class="section">
    <div class="section-body">
        <a href="@Url.Action("Add")" class="btn btn-primary">
            Add Credit Entry
        </a>

        <a href="@Url.Action("Print")" class="btn btn-primary">
            Print Report
        </a>
        <br />
        <br />
        <div class="card">

            <div class="card-header">
                <h4>Customer Credit Account</h4>
            </div>

            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-bordered table-hover" id="myTable">

                        <thead>
                            <tr>
                                <th>S.No</th>
                                <th>Date</th>
                                <th>Description</th>
                                <th>Add Amount</th>
                                <th>Minus Amount</th>
                                <th>Balance</th>
                                <th>Action</th>
                            </tr>
                        </thead>

                        <tbody>

                            @{
                                int i = 1;
                            }

                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@i</td>

                                    <td>
                                        @item.EntryDate.ToString("dd MMM yyyy")
                                    </td>

                                    <td>@item.Description</td>

                                    <td class="text-success font-weight-bold">
                                        @Math.Floor(item.AddAmount)
                                    </td>

                                    <td class="text-danger font-weight-bold">
                                        @Math.Floor(item.MinusAmount)
                                    </td>

                                    <td>
                                        @(Math.Floor(item.Balance) == 0 ? "Nill" : Math.Floor(item.Balance).ToString())
                                    </td>
                                    <td>
                                        <div class="dropdown">
                                            <button class="btn btn-warning dropdown-toggle"
                                                    data-toggle="dropdown">
                                                Options
                                            </button>
                                            <div class="dropdown-menu">
                                                <a class="dropdown-item"
                                                   href="@Url.Action("Edit", new { id = item.Id })">
                                                    Edit
                                                </a>
                                            </div>
                                        </div>
                                    </td>
                                </tr>

                                i++;
                            }

                        </tbody>

                    </table>

                </div>

            </div>
        </div>

    </div>

</section>