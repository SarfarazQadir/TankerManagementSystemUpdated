                padding: 0;
                box-shadow: 0 0 20px rgba(0,0,0,0.15);
                border-radius: 4px;
                overflow: hidden;
            }

            .header-top {
                background-color: var(--brand-color);
                color: var(--text-light);
                padding: 40px;
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

                .header-top h1 {
                    margin: 0;
                    font-size: 42px;
                    letter-spacing: 2px;
                    text-transform: uppercase;
                    font-weight: 300;
                }

            .logo-box img {
                max-height: 70px;
                filter: brightness(0) invert(1);
            }

            .info-section {
                display: grid;
                grid-template-columns: 1.5fr 1fr;
                padding: 30px 40px;
                background: var(--bg-soft);
                border-bottom: 1px solid #eee;
            }

            .bill-from h2 {
                margin: 0 0 10px 0;
                color: var(--brand-color);
                font-size: 24px;
            }

            .bill-details p {
                margin: 5px 0;
                font-size: 14px;
                display: flex;
                justify-content: space-between;
            }

            .content-area {
                padding: 40px;
            }

            table {
                width: 100%;
                border-collapse: collapse;
                margin-bottom: 30px;
            }

            thead th {
                background: #444;
                color: #fff;
                text-align: left;
                padding: 14px;
                font-size: 13px;
                text-transform: uppercase;
            }

            tbody tr:nth-child(even) {
                background: #fafafa;
            }

            tbody tr {
                border-bottom: 1px solid #eee;
            }

            td {
                padding: 14px;
                font-size: 15px;
            }

            .text-right {
                text-align: right;
            }

            .credit-text {
                color: var(--income-green);
                font-weight: bold;
            }

            .debit-text {
                color: var(--expense-red);
                font-weight: bold;
            }

            /* Date-wise Separator Row Styling */
            .date-divider {
                background-color: #f1f1f1 !important;
                font-weight: bold;
                color: var(--brand-color);
                font-size: 14px;
                border-top: 2px solid var(--brand-color);
                border-bottom: 2px solid var(--brand-color);
            }

            .footer-grid {
                display: grid;
                grid-template-columns: 1fr 320px;
                gap: 40px;
            }

            .terms {
                font-size: 13px;
                color: #777;
                padding-top: 20px;
            }

            .total-table {
                width: 100%;
            }

                .total-table td {
                    padding: 10px 0;
                    border: none;
                }

            .grand-total-row {
                background-color: var(--brand-color);
                color: white;
            }

                .grand-total-row td {
                    padding: 15px 10px !important;
                    font-size: 20px;
                    font-weight: bold;
                }

            .no-print-btn {
                text-align: center;
                padding: 20px;
            }

            .btn {
