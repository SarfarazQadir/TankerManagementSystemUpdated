<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Customer Credit Report</title>

    <style>
            :root {
                --brand-color: #86608E;
                --text-dark: #333;
                --text-light: #fff;
                --expense-red: #e74c3c;
                --income-green: #27ae60;
                --bg-soft: #f8f9fa;
            }

            body {
                font-family: 'Segoe UI', Arial, sans-serif;
                margin: 0;
                padding: 0;
                background-color: #e0e0e0;
