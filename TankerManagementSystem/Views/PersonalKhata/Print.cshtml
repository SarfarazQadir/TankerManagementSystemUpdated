<body>

    <div class="no-print-btn">
        <button class="btn" onclick="window.print()">
            PRINT REPORT
        </button>
    </div>

    <div class="invoice-wrapper">

        <div class="header-top">
            <div class="logo-box">
                <img src="~/img/flyeasy.png"
                     alt="LOGO"
                     onerror="this.src='https://via.placeholder.com/150x70?text=MALIK+BROS&bg=86608E&fg=fff'">
            </div>
            <h1>CREDIT REPORT</h1>
        </div>

        <div class="info-section">
            <div class="bill-from">
                <h2>MALIK & BROTHERS</h2>
                <p>Customer Credit Management</p>
                <p>
                    <strong>Total Entries:</strong> @Model.Count()
                </p>
                <p>
                    <strong>Remaining Credit:</strong>
                    @* Descending order ki waja se Model ka pehla record hi current balance hoga *@
                    @Math.Floor(Model.FirstOrDefault()?.Balance ?? 0)
                </p>
            </div>

            <div class="bill-details">
                <p>
                    <strong>Date:</strong>
                    <span>@DateTime.Now.ToString("dd MMM yyyy")</span>
                </p>
                <p>
                    <strong>Total Credit:</strong>
                    <span class="credit-text">@Math.Floor(totalAdd)</span>
                </p>
                <p>
                    <strong>Total Received:</strong>
                    <span class="debit-text">@Math.Floor(totalMinus)</span>
                </p>
                <p>
                    <strong>Net Balance:</strong>
                    <span>@Math.Floor(balance)</span>
                </p>
            </div>
        </div>

        <div class="content-area">
            <table>
                <thead>
                    <tr>
                        <th style="width: 5%">#</th>
                        <th style="width: 15%">Date</th>
                        <th style="width: 40%">Description</th>
                        <th class="text-right" style="width: 13%">Credit</th>
                        <th class="text-right" style="width: 13%">Received</th>
                        <th class="text-right" style="width: 14%">Balance</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int i = 1;
                        string lastDate = "";
                    }

                    @foreach (var item in Model)
                    {
                        string currentDate = item.EntryDate.ToString("dd MMM yyyy");

                        // Agar current record ki date pichle record se mukhtalif hai to divider line lagayein
                        if (lastDate != currentDate)
                        {
                            <tr class="date-divider">
                                <td colspan="6" style="padding: 8px 14px;">
                                    📅 Entries for: @currentDate
                                </td>
                            </tr>
                            lastDate = currentDate;
                        }

                        <tr>
                            <td>@i</td>
                            <td>@currentDate</td>
                            <td>@item.Description</td>
                            <td class="text-right credit-text">
                                @(item.AddAmount > 0 ? "+ " + Math.Floor(item.AddAmount) : "-")
                            </td>
                            <td class="text-right debit-text">
                                @(item.MinusAmount > 0 ? "- " + Math.Floor(item.MinusAmount) : "-")
                            </td>
                            <td class="text-right" style="font-weight: 500;">
                                @(item.Balance == 0 ? "Nill" : Math.Floor(item.Balance).ToString())
                            </td>
                        </tr>
                        i++;
                    }
                </tbody>
            </table>

            <div class="footer-grid">
                <div class="terms">
                    <p><strong>Notes:</strong></p>
                    <p>This report contains complete customer credit transactions including all credit and received payments.</p>
                    <br /><br />
                    <p>
                        __________________________
                        <br />
                        Authorised Signature
                    </p>
                </div>

                <div class="summary-box">
                    <table class="total-table">
                        <tr>
                            <td>Total Credit:</td>
                            <td class="text-right credit-text">@Math.Floor(totalAdd)</td>
                        </tr>
                        <tr>
                            <td>Total Received:</td>
                            <td class="text-right debit-text">@Math.Floor(totalMinus)</td>
                        </tr>
                        <tr class="grand-total-row">
                            <td>REMAINING:</td>
                            <td class="text-right">@Math.Floor(balance)</td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>

        <div style="background: var(--brand-color); height: 10px;"></div>
    </div>

</body>
</html>