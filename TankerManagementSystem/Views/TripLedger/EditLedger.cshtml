@* @model TankerManagementSystem.Models.ViewModels.TripLedgerVM

@{
    ViewData["Title"] = "EditLedger";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}

@{
    var trip = ViewBag.Trip;
    var expenses = ViewBag.Expenses as List<TankerManagementSystem.Models.TripExpense>;
}

<section class="section">

    <div class="section-body">

        <div class="row">

            <div class="col-12">

                <div class="card">

                    <div class="card-header">
                        <h4>Edit Trip Ledger</h4>
                    </div>

                    <div class="card-body">

                        <form method="post"
                              asp-action="EditLedger"
                              onsubmit="return validateEditLedgerForm(event)">

                            @Html.AntiForgeryToken()

                            <input type="hidden" asp-for="Id" />
                            <input type="hidden" asp-for="TripEntryId" />

                            <!-- TRIP ID -->
                            <div class="form-group row">

                                <label class="col-sm-3 col-form-label">
                                    Trip ID<span style="color:red;">*</span>
                                </label>

                                <div class="col-sm-9">

                                    <input type="text"
                                           id="TripId"
                                           value="@trip.Id"
                                           class="form-control"
                                           readonly />

                                </div>

                            </div>

                            <!-- TANKER -->
                            <div class="form-group row">

                                <label class="col-sm-3 col-form-label">
                                    Tanker No<span style="color:red;">*</span>
                                </label>

                                <div class="col-sm-9">

                                    <input type="text"
                                           id="TankerNo"
                                           value="@trip.TankerFk?.TankerNo"
                                           class="form-control"
                                           readonly />

                                </div>

                            </div>

                            <!-- FROM -->
                            <div class="form-group row">

                                <label class="col-sm-3 col-form-label">
                                    From<span style="color:red;">*</span>
                                </label>

                                <div class="col-sm-9">

                                    <input type="text"
                                           id="FromLocation"
                                           value="@trip.FromLocation"
                                           class="form-control"
                                           readonly />

                                </div>

                            </div>

                            <!-- TO -->
                            <div class="form-group row">

                                <label class="col-sm-3 col-form-label">
                                    To<span style="color:red;">*</span>
                                </label>

                                <div class="col-sm-9">

                                    <input type="text"
                                           id="ToLocation"
                                           value="@trip.ToLocation"
                                           class="form-control"
                                           readonly />

                                </div>

                            </div>

                            <!-- DATE -->
                            <div class="form-group row">

                                <label class="col-sm-3 col-form-label">
                                    Invoice Date<span style="color:red;">*</span>
                                </label>

                                <div class="col-sm-9">

                                    <input asp-for="TripDate"
                                           id="TripDate"
                                           type="date"
                                           class="form-control" />

                                </div>

                            </div>

                            <!-- PRODUCT -->
                            <div class="form-group row">

                                <label class="col-sm-3 col-form-label">
                                    Product<span style="color:red;">*</span>
                                </label>

                                <div class="col-sm-9">

                                    <select asp-for="ProductId"
                                            id="ProductId"
                                            class="form-control">

                                        <option value="">
                                            Select Product
                                        </option>

                                        @foreach (var p in ViewBag.Products)
                                        {
                                            <option value="@p.Id">
                                                @p.ProductName
                                            </option>
                                        }

                                    </select>

                                </div>

                            </div>

                            <!-- TOKEN -->
                            <div class="form-group row">

                                <label class="col-sm-3 col-form-label">
                                    Token No<span style="color:red;">*</span>
                                </label>

                                <div class="col-sm-9">

                                    <input asp-for="TokenNo"
                                           id="TokenNo"
                                           class="form-control" />

                                </div>

                            </div>

                            <!-- FREIGHT -->
                            <div class="form-group row">

                                <label style="color:green;"
                                       class="col-sm-3 col-form-label">

                                    Freight<span style="color:red;">*</span>

                                </label>

                                <div class="col-sm-9">

                                    <input asp-for="Freight"
                                           id="Freight"
                                           type="number"
                                           class="form-control" />

                                </div>

                            </div>

                            <!-- ADVANCE CASH -->
                            <div class="form-group row">

                                <label style="color:red;"
                                       class="col-sm-3 col-form-label">

                                    Advance Cash<span style="color:red;">*</span>

                                </label>

                                <div class="col-sm-9">

                                    <input asp-for="AdvanceCash"
                                           id="AdvanceCash"
                                           type="number"
                                           class="form-control" />

                                </div>

                            </div>

                            <!-- SHORTAGE -->
                            <div class="form-group row">

                                <label style="color:red;"
                                       class="col-sm-3 col-form-label">

                                    Shortage

                                </label>

                                <div class="col-sm-9">

                                    <input asp-for="Shortage"
                                           type="number"
                                           class="form-control" />

                                </div>

                            </div>

                            <!-- COMMISSION -->
                            <div class="form-group row">

                                <label style="color:red;"
                                       class="col-sm-3 col-form-label">

                                    Commission

                                </label>

                                <div class="col-sm-9">

                                    <input asp-for="Commission"
                                           type="number"
                                           class="form-control"
                                           readonly />

                                </div>

                            </div>

                            <!-- MUNSHIANA -->
                            <div class="form-group row">

                                <label style="color:red;"
                                       class="col-sm-3 col-form-label">

                                    Munshiana<span style="color:red;">*</span>

                                </label>

                                <div class="col-sm-9">

                                    <input asp-for="Munshiana"
                                           id="Munshiana"
                                           type="number"
                                           class="form-control" />

                                </div>

                            </div>

                            <!-- PREVIOUS BALANCE -->
                            <div class="form-group row">

                                <label style="color:red;"
                                       class="col-sm-3 col-form-label">

                                    Previous Balance (Tanker)

                                </label>

                                <div class="col-sm-9">

                                    <input type="number"
                                           id="tankerBalance"
                                           value="@ViewBag.TankerPreviousBalance"
                                           class="form-control"
                                           readonly />

                                </div>

                            </div>

                            <!-- REMARKS -->
                            <div class="form-group row">

                                <label class="col-sm-3 col-form-label">
                                    Remarks
                                </label>

                                <div class="col-sm-9">

                                    <textarea asp-for="Remarks"
                                              class="form-control"></textarea>

                                </div>

                            </div>

                            <hr />

                            <!-- EXPENSES -->
                            <h5>Expenses</h5>

                            <div id="expenseContainer">

                                @{
                                    int i = 0;
                                }

                                @if (expenses != null)
                                {
                                    @foreach (var item in expenses)
                                    {
                                        <div class="row mb-2">

                                            <div class="col-md-6">

                                                <input type="text"
                                                       name="expenses[@i].ExpenseName"
                                                       value="@item.ExpenseName"
                                                       class="form-control"
                                                       placeholder="Expense Name" />

                                            </div>

                                            <div class="col-md-4">

                                                <input type="number"
                                                       name="expenses[@i].Amount"
                                                       value="@item.Amount"
                                                       class="form-control"
                                                       placeholder="Amount" />

                                            </div>

                                        </div>

                                        i++;
                                    }
                                }

                                <input type="hidden"
                                       id="expenseIndex"
                                       value="@i" />

                            </div>

                            <!-- ADD EXPENSE -->
                            <button type="button"
                                    onclick="addExpense()"
                                    class="btn btn-info mb-3">

                                Add Expense

                            </button>

                            <!-- BUTTONS -->
                            <div class="card-footer text-center">

                                <input type="submit"
                                       id="submitBtn"
                                       value="Update Ledger"
                                       class="btn btn-primary" />

                                <a href="@Url.Action("Index")"
                                   class="btn btn-secondary">

                                    Back

                                </a>

                            </div>

                        </form>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>

<!-- VALIDATION -->
<script>

    function validateEditLedgerForm(event) {

        let tripDate =
            document.getElementById("TripDate").value.trim();

        let productId =
            document.getElementById("ProductId").value.trim();

        let tokenNo =
            document.getElementById("TokenNo").value.trim();

        let freight =
            document.getElementById("Freight").value.trim();

        let advanceCash =
            document.getElementById("AdvanceCash").value.trim();

        let munshiana =
            document.getElementById("Munshiana").value.trim();

        // Invoice Date
        if (tripDate === "") {

            iziToast.error({
                title: 'Error',
                message: 'Invoice Date is required!',
                position: 'bottomRight'
            });

            event.preventDefault();
            return false;
        }

        // Product
        if (productId === "") {

            iziToast.error({
                title: 'Error',
                message: 'Please select Product!',
                position: 'bottomRight'
            });

            event.preventDefault();
            return false;
        }

        // Token No
        if (tokenNo === "") {

            iziToast.error({
                title: 'Error',
                message: 'Token No is required!',
                position: 'bottomRight'
            });

            event.preventDefault();
            return false;
        }

        // Freight
        if (freight === "") {

            iziToast.error({
                title: 'Error',
                message: 'Freight is required!',
                position: 'bottomRight'
            });

            event.preventDefault();
            return false;
        }

        // Advance Cash
        if (advanceCash === "") {

            iziToast.error({
                title: 'Error',
                message: 'Advance Cash is required!',
                position: 'bottomRight'
            });

            event.preventDefault();
            return false;
        }

        // Munshiana
        if (munshiana === "") {

            iziToast.error({
                title: 'Error',
                message: 'Munshiana is required!',
                position: 'bottomRight'
            });

            event.preventDefault();
            return false;
        }

        // Expense Validation
        let expenseNames =
            document.querySelectorAll("input[name*='ExpenseName']");

        let expenseAmounts =
            document.querySelectorAll("input[name*='Amount']");

        for (let i = 0; i < expenseNames.length; i++) {

            let name =
                expenseNames[i].value.trim();

            let amount =
                expenseAmounts[i].value.trim();

            // Name hai amount nahi
            if (name !== "" && amount === "") {

                iziToast.error({
                    title: 'Error',
                    message: 'Please enter Expense Amount!',
                    position: 'bottomRight'
                });

                event.preventDefault();
                return false;
            }

            // Amount hai name nahi
            if (name === "" && amount !== "") {

                iziToast.error({
                    title: 'Error',
                    message: 'Please enter Expense Title!',
                    position: 'bottomRight'
                });

                event.preventDefault();
                return false;
            }

        }

        return true;
    }

</script>

<!-- SUBMIT BUTTON -->
<script>

    document.getElementById("submitBtn")
        .addEventListener("click", function (e) {

            if (validateEditLedgerForm(e)) {

                this.disabled = true;
                this.value = "Updating...";

                this.form.submit();
            }

        });

</script>

<!-- ADD EXPENSE -->
<script>

    function addExpense() {

        let container =
            document.getElementById("expenseContainer");

        let indexInput =
            document.getElementById("expenseIndex");

        let index =
            parseInt(indexInput.value);

        let div =
            document.createElement("div");

        div.className = "row mb-2";

        div.innerHTML = `

            <div class="col-md-6">

                <input type="text"
                       name="expenses[${index}].ExpenseName"
                       class="form-control"
                       placeholder="Expense Name" />

            </div>

            <div class="col-md-4">

                <input type="number"
                       name="expenses[${index}].Amount"
                       class="form-control"
                       placeholder="Amount" />

            </div>

        `;

        container.appendChild(div);

        indexInput.value = index + 1;
    }

</script> *@

@* @model TankerManagementSystem.Models.ViewModels.TripLedgerVM

@{
    ViewData["Title"] = "Edit Ledger";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}

@{
    var trip = ViewBag.Trip;
    var expenses = ViewBag.Expenses as List<TankerManagementSystem.Models.TripExpense>;
}

<section class="section">
    <div class="section-body">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h4>Edit Trip Ledger</h4>
                    </div>

                    <div class="card-body">
                        <form method="post" asp-action="EditLedger" id="editLedgerForm">
                            @Html.AntiForgeryToken()

                            <input type="hidden" asp-for="Id" />
                            <input type="hidden" asp-for="TripEntryId" />

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label">Trip ID<span class="text-danger">*</span></label>
                                <div class="col-sm-9">
                                    <input type="text" id="TripId" value="@trip?.Id" class="form-control" readonly />
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label">Tanker No<span class="text-danger">*</span></label>
                                <div class="col-sm-9">
                                    <input type="text" id="TankerNo" value="@trip?.TankerFk?.TankerNo" class="form-control" readonly />
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label">From<span class="text-danger">*</span></label>
                                <div class="col-sm-9">
                                    <input type="text" id="FromLocation" value="@trip?.FromLocation" class="form-control" readonly />
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label">To<span class="text-danger">*</span></label>
                                <div class="col-sm-9">
                                    <input type="text" id="ToLocation" value="@trip?.ToLocation" class="form-control" readonly />
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label">Invoice Date<span class="text-danger">*</span></label>
                                <div class="col-sm-9">
                                    <input asp-for="TripDate" id="TripDate" type="date" class="form-control" />
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label">Product<span class="text-danger">*</span></label>
                                <div class="col-sm-9">
                                    <select asp-for="ProductId" id="ProductId" class="form-control">
                                        <option value="">Select Product</option>
                                        @foreach (var p in ViewBag.Products)
                                        {
                                            <! -- Saved product automatically select karne k liye logic -->
                                            <option value="@p.Id" selected="@(p.Id == Model.ProductId ? "selected" : null)">
                                                @p.ProductName
                                            </option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label">Token No<span class="text-danger">*</span></label>
                                <div class="col-sm-9">
                                    <input asp-for="TokenNo" id="TokenNo" class="form-control" />
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label text-success font-weight-bold">Freight<span class="text-danger">*</span></label>
                                <div class="col-sm-9">
                                    <input asp-for="Freight" id="Freight" type="number" step="any" class="form-control" />
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label text-danger font-weight-bold">Advance Cash<span class="text-danger">*</span></label>
                                <div class="col-sm-9">
                                    <input asp-for="AdvanceCash" id="AdvanceCash" type="number" step="any" class="form-control" />
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label text-danger font-weight-bold">Shortage</label>
                                <div class="col-sm-9">
                                    <input asp-for="Shortage" type="number" step="any" class="form-control" />
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label text-danger font-weight-bold">Commission</label>
