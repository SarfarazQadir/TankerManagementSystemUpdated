                                        <option value="">Select Product</option>
                                        @foreach (var p in ViewBag.Products)
                                        {
                                            <option value="@p.Id" selected="@(p.Id == Model.ProductId ? "selected" : null)">
                                                @p.ProductName
                                            </option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label">Token No<span class="text-danger">*</span></label>
                                <div class="col-sm-9">
                                    <input asp-for="TokenNo" id="TokenNo" class="form-control" />
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label text-success font-weight-bold">Freight<span class="text-danger">*</span></label>
                                <div class="col-sm-9">
                                    <input asp-for="Freight" id="Freight" type="number" step="any" class="form-control" />
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label text-danger font-weight-bold">Advance Cash<span class="text-danger">*</span></label>
                                <div class="col-sm-9">
                                    <input asp-for="AdvanceCash" id="AdvanceCash" type="number" step="any" class="form-control" />
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label text-danger font-weight-bold">Shortage</label>
                                <div class="col-sm-9">
                                    <input asp-for="Shortage" type="number" step="any" class="form-control" />
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label text-danger font-weight-bold">Commission</label>
                                <div class="col-sm-9">
                                    <input asp-for="Commission" type="number" step="any" class="form-control" readonly />
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label text-danger font-weight-bold">Munshiana<span class="text-danger">*</span></label>
                                <div class="col-sm-9">
                                    <input asp-for="Munshiana" id="Munshiana" type="number" step="any" class="form-control" />
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label text-danger font-weight-bold">Previous Balance (Tanker)</label>
                                <div class="col-sm-9">
                                    <input type="number" id="tankerBalance" value="@ViewBag.TankerPreviousBalance" class="form-control" readonly />
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label">Remarks</label>
                                <div class="col-sm-9">
                                    <textarea asp-for="Remarks" class="form-control" rows="3"></textarea>
                                </div>
                            </div>

                            <hr />

                            <h5 class="mb-3">Expenses</h5>

                            <div id="expenseContainer" class="font-weight-bold">
                                @{
                                    int i = 0;
                                }
                                @if (expenses != null)
                                {
                                    @foreach (var item in expenses)
                                    {
                                        <div class="row mb-2 expense-row">
                                            <div class="col-md-5">
                                                <input type="text" name="expenses[@i].ExpenseName" value="@item.ExpenseName" class="form-control expense-name" placeholder="Expense Name" />
                                            </div>
                                            <div class="col-md-5">
                                                <input type="number" step="any" name="expenses[@i].Amount" value="@item.Amount" class="form-control expense-amount" placeholder="Amount" />
                                            </div>
                                            <div class="col-md-2">
                                                <button type="button" class="btn btn-danger btn-block" onclick="removeExpense(this)">Remove</button>
                                            </div>
                                        </div>
                                        i++;
                                    }
                                }
                                <input type="hidden" id="expenseIndex" value="@i" />
                            </div>

                            <button type="button" onclick="addExpense()" class="btn btn-info mb-4 mt-2">Add Expense</button>

                            <div class="card-footer text-center bg-transparent border-top-0">
                                <button type="submit" id="submitBtn" class="btn btn-primary mr-2">Update Ledger</button>
                                <a href="@Url.Action("Index")" class="btn btn-secondary">Back</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    function validateEditLedgerForm() {
        let tripDate = document.getElementById("TripDate").value.trim();
        let productId = document.getElementById("ProductId").value.trim();
        let tokenNo = document.getElementById("TokenNo").value.trim();
        let freight = document.getElementById("Freight").value.trim();
        let advanceCash = document.getElementById("AdvanceCash").value.trim();
        let munshiana = document.getElementById("Munshiana").value.trim();

        if (tripDate === "") return showValidationError('Invoice Date is required!');
        if (productId === "") return showValidationError('Please select Product!');
        if (tokenNo === "") return showValidationError('Token No is required!');
        if (freight === "") return showValidationError('Freight is required!');
        if (advanceCash === "") return showValidationError('Advance Cash is required!');
        if (munshiana === "") return showValidationError('Munshiana is required!');

        let expenseNames = document.querySelectorAll(".expense-name");
        let expenseAmounts = document.querySelectorAll(".expense-amount");

        for (let i = 0; i < expenseNames.length; i++) {
            let name = expenseNames[i].value.trim();
            let amount = expenseAmounts[i].value.trim();

            if (name !== "" && amount === "") return showValidationError('Please enter Expense Amount!');
            if (name === "" && amount !== "") return showValidationError('Please enter Expense Title!');
        }
        return true;
    }

    function showValidationError(message) {
        iziToast.error({
            title: 'Error',
            message: message,
            position: 'bottomRight'
        });
        return false;
    }

    document.getElementById("editLedgerForm").addEventListener("submit", function (e) {
        if (!validateEditLedgerForm()) {
            e.preventDefault();
        } else {
            let btn = document.getElementById("submitBtn");
            btn.disabled = true;
            btn.innerHTML = "Updating...";
        }
    });

    function addExpense() {
        let container = document.getElementById("expenseContainer");
        let indexInput = document.getElementById("expenseIndex");
        let index = parseInt(indexInput.value);

        let div = document.createElement("div");
        div.className = "row mb-2 expense-row";
        div.innerHTML = `
            <div class="col-md-5">
                <input type="text" name="expenses[${index}].ExpenseName" class="form-control expense-name" placeholder="Expense Name" />
            </div>
            <div class="col-md-5">
                <input type="number" step="any" name="expenses[${index}].Amount" class="form-control expense-amount" placeholder="Amount" />
            </div>
            <div class="col-md-2">
                <button type="button" class="btn btn-danger btn-block" onclick="removeExpense(this)">Remove</button>
            </div>
        `;
        // Hidden field se pehle insert karne ke liye taake tracker hamesha end me rahe
        container.insertBefore(div, indexInput);
        indexInput.value = index + 1;
    }

    function removeExpense(button) {
        button.closest('.expense-row').remove();
        reIndexExpenses();
    }

    function reIndexExpenses() {
        let rows = document.querySelectorAll('.expense-row');
        let indexInput = document.getElementById("expenseIndex");

        rows.forEach((row, newIndex) => {
            let nameInput = row.querySelector(".expense-name");
            let amountInput = row.querySelector(".expense-amount");

            if(nameInput) nameInput.name = `expenses[${newIndex}].ExpenseName`;
            if(amountInput) amountInput.name = `expenses[${newIndex}].Amount`;
        });

        indexInput.value = rows.length;
    }
</script> *@


@model TankerManagementSystem.Models.ViewModels.TripLedgerVM

@{
    ViewData["Title"] = "Edit Ledger";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}

@{
    var trip = ViewBag.Trip;
    decimal? prevBalance = ViewBag.TankerPreviousBalance as decimal?;
}

<section class="section">
    <div class="section-body">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h4>Edit Trip Ledger</h4>
                    </div>

                    <div class="card-body">
                        <form method="post" asp-action="EditLedger" id="editLedgerForm">
                            @Html.AntiForgeryToken()

                            <input type="hidden" asp-for="Id" />
                            <input type="hidden" asp-for="TripEntryId" />

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label">Trip ID</label>
                                <div class="col-sm-9">
                                    <input type="text" id="TripId" value="@trip?.Id" class="form-control" readonly />
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label">Tanker No</label>
                                <div class="col-sm-9">
                                    <input type="text" id="TankerNo" value="@trip?.TankerFk?.TankerNo" class="form-control" readonly />
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label">From</label>
                                <div class="col-sm-9">
                                    <input type="text" id="FromLocation" value="@trip?.FromLocation" class="form-control" readonly />
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label">To</label>
                                <div class="col-sm-9">
                                    <input type="text" id="ToLocation" value="@trip?.ToLocation" class="form-control" readonly />
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label">Invoice Date<span class="text-danger">*</span></label>
                                <div class="col-sm-9">
                                    <input asp-for="TripDate" id="TripDate" type="date" class="form-control" />
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label">Product<span class="text-danger">*</span></label>
                                <div class="col-sm-9">
                                    <select asp-for="ProductId" id="ProductId" class="form-control">
                                        <option value="">Select Product</option>
                                        @foreach (var p in ViewBag.Products)
                                        {
                                            <option value="@p.Id" selected="@(p.Id == Model.ProductId ? "selected" : null)">
                                                @p.ProductName
                                            </option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label">Token No<span class="text-danger">*</span></label>
                                <div class="col-sm-9">
                                    <input asp-for="TokenNo" id="TokenNo" class="form-control" placeholder="Enter Token Number" />
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label text-success font-weight-bold">Freight<span class="text-danger">*</span></label>
                                <div class="col-sm-9">
                                    <input asp-for="Freight" id="Freight" type="number" step="any" class="form-control" placeholder="0.00" />
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label text-danger font-weight-bold">Advance Cash<span class="text-danger">*</span></label>
                                <div class="col-sm-9">
                                    <input asp-for="AdvanceCash" id="AdvanceCash" type="number" step="any" class="form-control" placeholder="0.00" oninput="checkAdvanceAlert()" />
                                    <small id="advanceHelp" class="form-text text-muted d-none">✨ Active advance amount detected for this trip ledger transaction.</small>
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label text-danger font-weight-bold">Shortage</label>
                                <div class="col-sm-9">
                                    <input asp-for="Shortage" type="number" step="any" class="form-control" placeholder="0.00" />
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label text-danger font-weight-bold">Commission</label>
                                <div class="col-sm-9">
                                    <input asp-for="Commission" type="number" step="any" class="form-control" placeholder="0.00" readonly />
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label text-danger font-weight-bold">Munshiana<span class="text-danger">*</span></label>
                                <div class="col-sm-9">
                                    <input asp-for="Munshiana" id="Munshiana" type="number" step="any" class="form-control" placeholder="0.00" />
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label text-warning font-weight-bold">Previous Balance (Tanker)</label>
                                <div class="col-sm-9">
                                    @if (prevBalance.HasValue && prevBalance.Value != 0)
                                    {
                                        <div class="input-group">
                                            <div class="input-group-prepend">
                                                <span class="input-group-text bg-warning text-white"><i class="fas fa-wallet"></i></span>
                                            </div>
                                            <input type="text" value="@string.Format("{0:N2}", prevBalance.Value)" class="form-control font-weight-bold text-dark bg-light" readonly />
                                        </div>
                                        <small class="form-text text-warning">Outstanding dues exist for this tanker.</small>
                                    }
                                    else
                                    {
                                        <input type="text" value="Nil (No Outstanding Balance)" class="form-control text-muted bg-light italic" readonly />
                                    }
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label">Remarks</label>
                                <div class="col-sm-9">
                                    <textarea asp-for="Remarks" class="form-control" rows="3" placeholder="Optional internal logs..."></textarea>
                                </div>
                            </div>

                            <div class="card-footer text-center bg-transparent border-top-0">
                                <button type="submit" id="submitBtn" class="btn btn-primary mr-2">Update Ledger</button>
                                <a href="@Url.Action("Index")" class="btn btn-secondary">Cancel</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    // Execute on page load to initialize advance cash tracking state
    document.addEventListener("DOMContentLoaded", function() {
        checkAdvanceAlert();
    });

    // Advance cash highlight monitor
    function checkAdvanceAlert() {
        let advInput = document.getElementById("AdvanceCash");
        let advHelp = document.getElementById("advanceHelp");
        if (!advInput) return;

        let val = parseFloat(advInput.value);

        if (!isNaN(val) && val > 0) {
            advHelp.classList.remove("d-none");
            advInput.classList.add("is-invalid");
        } else {
            advHelp.classList.add("d-none");
            advInput.classList.remove("is-invalid");
        }
    }

    function validateEditLedgerForm() {
        let tripDate = document.getElementById("TripDate").value.trim();
        let productId = document.getElementById("ProductId").value.trim();
        let tokenNo = document.getElementById("TokenNo").value.trim();
        let freight = document.getElementById("Freight").value.trim();
        let advanceCash = document.getElementById("AdvanceCash").value.trim();
        let munshiana = document.getElementById("Munshiana").value.trim();

        if (tripDate === "") return showValidationError('Invoice Date status tracking required!');
        if (productId === "") return showValidationError('Please map a standard Product profile!');
        if (tokenNo === "") return showValidationError('Token Number verification string missing!');
        if (freight === "") return showValidationError('Freight base numerical calculation target required!');
        if (advanceCash === "") return showValidationError('Advance Cash value field is required!');
        if (munshiana === "") return showValidationError('Munshiana records are required!');

        return true;
    }

    function showValidationError(message) {
        iziToast.error({
            title: 'Form Validation Error',
            message: message,
            position: 'bottomRight'
        });
        return false;
    }

    document.getElementById("editLedgerForm").addEventListener("submit", function (e) {
        if (!validateEditLedgerForm()) {
            e.preventDefault();
        } else {
            let btn = document.getElementById("submitBtn");
            btn.disabled = true;
            btn.innerHTML = "<i class=\"fas fa-spinner fa-spin\"></i> Updating Records...";
        }
    });
</script>