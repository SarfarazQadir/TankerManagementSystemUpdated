@model IEnumerable<TankerManagementSystem.Models.TripLedger>

@{
    ViewData["Title"] = "Trip Transactions";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}

@if (TempData["add_ledger"] != null)
{
    <script>
        Swal.fire({
            title: '@TempData["add_ledger"]',
            icon: 'success'
        });
    </script>
}

@if (TempData["edit_ledger"] != null)
{
    <script>
        Swal.fire({
            title: '@TempData["edit_ledger"]',
            icon: 'success'
        });
    </script>
}

<section class="section">
    <div class="section-body">
        <div class="card mt-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4>Trip Transaction Details</h4>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-bordered table-hover w-100" id="myTable">
                        <thead class="bg-light">
                            <tr>
                                <th style="width: 5%;">S.No</th>
                                <th>Token No</th>
                                <th>Trip From</th>
                                <th>Trip To</th>
                                <th>Product</th>
                                <th>Freight</th>
                                <th>Grand Total</th>
                                <th class="text-center" style="width: 15%;">Action</th>
                            </tr>
                        </thead>

                        <tbody>
                            @{
                                int i = 1;
                            }
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@i</td>
                                    <td><span class="badge badge-light font-weight-bold">@item.TokenNo</span></td>
                                    <td>@item.TripEntryFk?.FromLocation</td>
                                    <td>@item.TripEntryFk?.ToLocation</td>
                                    <td>@item.Product?.ProductName</td>
                                    <! -- Null Check safely string formatting k sath -->
                                    <td>@string.Format("{0:N0}", item.Freight)</td>
                                    <td><span class="text-success font-weight-bold">@string.Format("{0:N0}", item.GrandTotal)</span></td>

                                    <td class="text-center">
                                        <div class="dropdown d-inline">
                                            <button data-toggle="dropdown" class="btn btn-warning btn-sm dropdown-toggle">Options</button>
                                            <div class="dropdown-menu dropdown-menu-right">
                                                <a href="@Url.Action("EditLedger", new { id = item.Id })" class="dropdown-item has-icon">
                                                    <i class="far fa-edit text-primary"></i> Edit
                                                </a>
                                                <a href="@Url.Action("PrintBill", new { id = item.Id })" class="dropdown-item has-icon">
                                                    <i class="far fa-print text-success"></i> Print
                                                </a>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                                i++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section> *@

@model IEnumerable<TankerManagementSystem.Models.TripLedger>

