<script>

    function validateLedgerForm(event) {

        let tripDate = document.getElementById("TripDate").value.trim();
        let productId = document.getElementById("ProductId").value.trim();
        let tokenNo = document.getElementById("TokenNo").value.trim();
        let freight = document.getElementById("Freight").value.trim();
        let advanceCash = document.getElementById("AdvanceCash").value.trim();
        let munshiana = document.getElementById("Munshiana").value.trim();

        // Invoice Date
        if (tripDate === "") {

            iziToast.error({
                title: 'Error',
                message: 'Invoice Date is required!',
                position: 'bottomRight'
            });

            event.preventDefault();
            return false;
        }

        // Product
        if (productId === "") {

            iziToast.error({
                title: 'Error',
                message: 'Please select Product!',
                position: 'bottomRight'
            });

            event.preventDefault();
            return false;
        }

        // Token No
        if (tokenNo === "") {

            iziToast.error({
                title: 'Error',
                message: 'Token No is required!',
                position: 'bottomRight'
            });

            event.preventDefault();
            return false;
        }

        // Freight
        if (freight === "") {

            iziToast.error({
                title: 'Error',
                message: 'Freight is required!',
                position: 'bottomRight'
            });

            event.preventDefault();
            return false;
        }

        // Advance Cash
        if (advanceCash === "") {

            iziToast.error({
                title: 'Error',
                message: 'Advance Cash is required!',
                position: 'bottomRight'
            });

            event.preventDefault();
            return false;
        }

        // Munshiana
        if (munshiana === "") {

            iziToast.error({
                title: 'Error',
                message: 'Munshiana is required!',
                position: 'bottomRight'
            });

            event.preventDefault();
            return false;
        }

        // Expense Validation
        let expenseNames = document.querySelectorAll("input[name*='ExpenseName']");
        let expenseAmounts = document.querySelectorAll("input[name*='Amount']");

        for (let i = 0; i < expenseNames.length; i++) {

            let name = expenseNames[i].value.trim();
            let amount = expenseAmounts[i].value.trim();

            // Name hai amount nahi
            if (name !== "" && amount === "") {

                iziToast.error({
                    title: 'Error',
                    message: 'Please enter Expense Amount!',
                    position: 'bottomRight'
                });

                event.preventDefault();
                return false;
            }

            // Amount hai name nahi
            if (name === "" && amount !== "") {

                iziToast.error({
                    title: 'Error',
                    message: 'Please enter Expense Title!',
                    position: 'bottomRight'
                });

                event.preventDefault();
                return false;
            }

            // Dono empty => no validation
        }

        return true;
    }

</script>

<script>

    document.getElementById("submitBtn").addEventListener("click", function (e) {

        if (validateLedgerForm(e)) {

            this.disabled = true;
            this.value = "Saving...";
            this.form.submit();
        }

    });

</script>

<script>

    function addExpense() {

        let container = document.getElementById("expenseContainer");
        let indexInput = document.getElementById("expenseIndex");

        let index = parseInt(indexInput.value);

        let div = document.createElement("div");
        div.className = "row mb-2";

        div.innerHTML = `

            <div class="col-md-6">

                <input type="text"
                       name="expenses[${index}].ExpenseName"
                       class="form-control"
                       placeholder="Expense Name" />

            </div>

            <div class="col-md-4">

                <input type="number"
                       name="expenses[${index}].Amount"
                       class="form-control"
                       placeholder="Amount" />

            </div>

        `;

        container.appendChild(div);

        indexInput.value = index + 1;
    }

</script> *@

