        .content-area {
            padding: 40px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead th {
            background: #444;
            color: #fff;
            padding: 12px;
        }

        td {
            padding: 12px;
        }

        .text-right {
            text-align: right;
        }

        .expense-text {
            color: #e74c3c;
            font-weight: 600;
        }

        .footer-grid {
            display: grid;
            grid-template-columns: 1fr 300px;
            gap: 40px;
        }

        .grand-total-row {
            background-color: var(--brand-color);
            color: white;
        }

            .grand-total-row td {
                font-size: 20px;
                font-weight: bold;
            }

        .no-print-btn {
            text-align: center;
            padding: 20px;
        }

        @@media print {
            .no-print-btn {
                display: none;
            }
        }
    </style>
</head>

<body>

    <div class="no-print-btn">
        <button onclick="window.print()">PRINT INVOICE</button>
    </div>

    <div class="invoice-wrapper">

        <!-- HEADER -->
        <div class="header-top">
            <div class="logo-box">
                <img src="~/img/flyeasy.png" />
            </div>
            <h1>INVOICE</h1>
        </div>

        <!-- INFO -->
        <div class="info-section">
            <div>
                <h2>MALIK AND BROTHERS</h2>
                <p><strong>Tanker:</strong> @Model.TripEntryFk?.TankerFk?.TankerNo</p>
                <p><strong>Route:</strong> @Model.TripEntryFk?.FromLocation → @Model.TripEntryFk?.ToLocation</p>
            </div>

            <div>
                <p><strong>Invoice:</strong> #@Model.TripEntryId</p>
                <p><strong>Date:</strong> @Model.TripDate.ToString("dd MMM yyyy")</p>
                <p><strong>Token:</strong> @Model.TokenNo</p>
            </div>
        </div>

        <!-- TABLE -->
        <div class="content-area">
            <table>
                <thead>
                    <tr>
                        <th>Description</th>
                        <th class="text-right">Amount</th>
                    </tr>
                </thead>

                <tbody>

                    <tr>
                        <td>Freight</td>
                        <td class="text-right">@Math.Floor(Model.Freight)</td>
                    </tr>

                    <tr class="expense-text">
                        <td>Advance</td>
                        <td class="text-right">- @Math.Floor(Model.AdvanceCash)</td>
                    </tr>

                    <tr class="expense-text">
                        <td>Shortage</td>
                        <td class="text-right">- @Math.Floor(Model.Shortage)</td>
                    </tr>

                    <tr class="expense-text">
                        <td>Commission</td>
                        <td class="text-right">- @Math.Floor(Model.Commission)</td>
                    </tr>

                    <tr class="expense-text">
                        <td>Munshiana</td>
                        <td class="text-right">- @Math.Floor(Model.Munshiana)</td>
                    </tr>

                    <!-- ✅ FIXED: AmountPay instead of PreviousBalance -->
                    <tr class="expense-text">
                        <td>Paid Amount</td>
                        <td class="text-right">- @Math.Floor(Model.AmountPay ?? 0)</td>
                    </tr>

                    <!-- Expenses -->
                    @foreach (var exp in Model.Expenses)
                    {
                        <tr class="expense-text">
                            <td>@exp.ExpenseName</td>
                            <td class="text-right">- @Math.Floor(exp.Amount)</td>
                        </tr>
                    }

                </tbody>
            </table>

            <!-- SUMMARY -->
            <div class="footer-grid">

                <div>
                    <p><strong>Remarks:</strong></p>
                    <p>@Model.Remarks</p>
                </div>

                <div>
                    <table>
                        <tr>
                            <td>Gross</td>
                            <td class="text-right">@Math.Floor(Model.Freight)</td>
                        </tr>

                        <!-- ✅ NO CALCULATION -->
                        <tr>
                            <td>Total Deductions</td>
                            <td class="text-right">@Math.Floor(Model.TotalDeductions)</td>
                        </tr>

                        <!-- ✅ FINAL VALUE FROM DB -->
                        <tr class="grand-total-row">
                            <td>Total Due</td>
                            <td class="text-right">@Math.Floor(Model.GrandTotal)</td>
                        </tr>

                    </table>
                </div>

            </div>

        </div>
    </div>

</body>
</html> *@