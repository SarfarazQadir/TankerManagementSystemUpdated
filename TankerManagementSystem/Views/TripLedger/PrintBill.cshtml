<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Invoice - @Model.TripEntryId</title>

    <!-- ✅ SAME CSS (NO CHANGE) -->
    <style>
        :root {
            --brand-color: #86608E;
            --text-dark: #333;
            --text-light: #fff;
            --expense-red: #e74c3c;
            --bg-soft: #f8f9fa;
