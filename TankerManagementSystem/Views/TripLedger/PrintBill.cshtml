@model TankerManagementSystem.Models.TripLedger
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Invoice - @Model.TripEntryId</title>
    <style>
        :root {
            --brand-color: #86608E;
            --text-dark: #333;
            --text-light: #fff;
            --expense-red: #e74c3c;
            --bg-soft: #f8f9fa;
        }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            margin: 0;
            padding: 0;
            background-color: #e0e0e0;
            color: var(--text-dark);
        }

        .invoice-wrapper {
            max-width: 850px;
            margin: 30px auto;
            background: #fff;
            padding: 0;
            box-shadow: 0 0 20px rgba(0,0,0,0.15);
            border-radius: 4px;
            overflow: hidden;
        }

        /* Header Section from Image 2 inspiration */
        .header-top {
            background-color: var(--brand-color);
            color: var(--text-light);
            padding: 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .header-top h1 {
                margin: 0;
                font-size: 45px;
                letter-spacing: 2px;
                text-transform: uppercase;
                font-weight: 300;
            }

        .logo-box img {
            max-height: 70px;
            filter: brightness(0) invert(1); /* Makes logo white to match theme */
        }

        /* Info Section from Image 2/3 */
        .info-section {
            display: grid;
            grid-template-columns: 1.5fr 1fr;
            padding: 30px 40px;
            background: var(--bg-soft);
            border-bottom: 1px solid #eee;
        }

        .bill-from h2 {
            margin: 0 0 10px 0;
            color: var(--brand-color);
            font-size: 22px;
        }

        .bill-details p {
            margin: 4px 0;
            font-size: 14px;
            display: flex;
            justify-content: space-between;
        }

        /* Table Style from Image 3 */
        .content-area {
            padding: 40px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 30px;
        }

        thead th {
            background: #444;
            color: #fff;
            text-align: left;
            padding: 12px;
            font-size: 13px;
            text-transform: uppercase;
        }

        tbody tr:nth-child(even) {
            background: #fdfdfd;
        }

        tbody tr {
            border-bottom: 1px solid #eee;
        }

        td {
            padding: 15px 12px;
            font-size: 15px;
        }

        .text-right {
            text-align: right;
        }

        .expense-text {
            color: var(--expense-red);
            font-weight: 600;
        }

        /* Summary Section from Image 1/3 */
        .footer-grid {
            display: grid;
            grid-template-columns: 1fr 300px;
            gap: 40px;
        }

        .terms {
            font-size: 12px;
            color: #777;
            padding-top: 20px;
        }

        .total-table {
            width: 100%;
        }

            .total-table td {
                padding: 8px 0;
                border: none;
            }

        .grand-total-row {
            background-color: var(--brand-color);
            color: white;
            border-radius: 4px;
        }

            .grand-total-row td {
                padding: 15px 10px !important;
                font-size: 20px;
                font-weight: bold;
            }

        .no-print-btn {
            text-align: center;
            padding: 20px;
        }

        .btn {
            background: var(--brand-color);
            color: white;
            border: none;
            padding: 10px 30px;
            border-radius: 20px;
            cursor: pointer;
            font-weight: bold;
        }

        @@media print {
            .no-print-btn

        {
            display: none;
        }

        body {
            background: transparent;
        }

        .invoice-wrapper {
            box-shadow: none;
            margin: 0;
        }

        .header-top {
            -webkit-print-color-adjust: exact;
        }

        }
    </style>
</head>
<body>

    <div class="no-print-btn">
        <button class="btn" onclick="window.print()">PRINT INVOICE</button>
    </div>

    <div class="invoice-wrapper">
        <!-- Blue Header -->
        <div class="header-top">
            <div class="logo-box">
                <img src="~/img/flyeasy.png" alt="LOGO" onerror="this.src='https://via.placeholder.com/150x70?text=MALIK+BROS&bg=86608E&fg=fff'">
            </div>
            <h1>INVOICE</h1>
        </div>

        <!-- Info Grid -->
        <div class="info-section">
            <div class="bill-from">
                <h2>MALIK AND BROTHERS</h2>
                <p>Tanker Management Services</p>
                <p><strong>Tanker No:</strong> @Model.TripEntryFk?.TankerFk?.TankerNo</p>
                <p><strong>Route:</strong> @Model.TripEntryFk?.FromLocation to @Model.TripEntryFk?.ToLocation</p>
            </div>
            <div class="bill-details">
                <p><strong>Invoice No:</strong> <span>#@Model.TripEntryId</span></p>
                <p><strong>Date:</strong> <span>@Model.TripDate.ToString("dd MMM, yyyy")</span></p>
                <p><strong>Token No:</strong> <span>@Model.TokenNo</span></p>
                <p><strong>Product:</strong> <span>@Model.Product?.ProductName</span></p>
            </div>
        </div>

        <div class="content-area">
            <table>
                <thead>
                    <tr>
                        <th>Description</th>
                        <th class="text-right">Amount (PKR)</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Income -->
                    <tr>
                        <td><strong>Total Freight (Basic)</strong></td>
                        <td class="text-right">@Math.Floor(Model.Freight)</td>
                    </tr>

                    <!-- Expenses (Red & No Decimals) -->
                    <tr class="expense-text">
                        <td>Advance Cash</td>
                        <td class="text-right">- @Math.Floor(Model.AdvanceCash)</td>
                    </tr>
                    <tr class="expense-text">
                        <td>Shortage Deductions</td>
                        <td class="text-right">- @Math.Floor(Model.Shortage)</td>
                    </tr>
                    <tr class="expense-text">
                        <td>Commission</td>
                        <td class="text-right">- @Math.Floor(Model.Commission)</td>
                    </tr>
                    <tr class="expense-text">
                        <td>Munshiana</td>
                        <td class="text-right">- @Math.Floor(Model.Munshiana)</td>
                    </tr>
                    <tr class="expense-text">
                        <td>Previous Paid / Balance Adjustment</td>
                        @{

                        }
                        <td class="text-right">- @Math.Floor(Model.AmountPay ?? 0)</td>
                    </tr>

                    <!-- Dynamic Expenses -->
                    @foreach (var exp in Model.Expenses)
                    {
                        if (exp.TripLedgerId == Model.Id)
                        {
                        <tr class="expense-text">
                            <td>@exp.ExpenseName</td>
                            <td class="text-right">- @Math.Floor(exp.Amount)</td>
                        </tr>
                        }
                    }
                </tbody>
            </table>

            <div class="footer-grid">
                <div class="terms">
                    <p><strong>Notes / Remarks:</strong></p>
                    <p>@(string.IsNullOrEmpty(Model.Remarks) ? "No additional remarks for this trip." : Model.Remarks)</p>
                    <br><br>
                    <p>__________________________<br>Authorised Signature</p>
                </div>

                <div class="summary-box">
                 @*    <table class="total-table">
                        <tr>
                            <td>Gross Freight:</td>
                            <td class="text-right">@Math.Floor(Model.Freight)</td>
                        </tr>
                        <tr>
                            <td class="expense-text">Total Deductions:</td>
                            <td class="text-right expense-text">
                             
                                @Math.Floor(Model.TotalDeductions)
                            </td>
                        </tr>
                        <tr>
                            <td class="expense-text">Previous Dues Paid:</td>
                            <td class="text-right expense-text">
                             
                                @Math.Floor(Model.AmountPay ?? 0)
                            </td>
                        </tr>
                        <tr class="grand-total-row">
                            <td>TOTAL DUE:</td>
                                @{
                                    var Totall = Model.GrandTotal - Model.AmountPay;
                                }
                            <td class="text-right">
                               
                                 @Math.Floor(Model.GrandTotal) 
                                
                            </td>
                        </tr>
                    </table> *@

                    <table class="total-table">
                        <tr>
                            <td>Gross Freight:</td>
                            <td class="text-right">
                                @Math.Floor(Model.Freight)
                            </td>
                        </tr>

                        <tr>
                            <td class="expense-text">Total Deductions:</td>
                            <td class="text-right expense-text">
                                @Math.Floor(Model.TotalDeductions)
                            </td>
                        </tr>

                        <tr>
                            <td class="expense-text">Previous Dues Paid:</td>
                            <td class="text-right expense-text">
                                @Math.Floor(Model.AmountPay ?? 0m)
                            </td>
                        </tr>

                        <tr class="grand-total-row" style="background-color: #86608E !important">
                            <td>TOTAL DUE:</td>
                            <td class="text-right">
                                @Math.Floor(Model.GrandTotal - (Model.AmountPay ?? 0m))
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>

        <div style="background: var(--brand-color); height: 10px; width: 100%;"></div>
    </div>

</body>
</html>

@* @model TankerManagementSystem.Models.TripLedger
@{
    Layout = null;
