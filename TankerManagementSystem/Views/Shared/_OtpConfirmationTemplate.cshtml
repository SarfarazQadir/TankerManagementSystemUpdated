@model dynamic

<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Tanker Management System Verification</title>

    <style>

            body {
                margin: 0;
                padding: 0;
                background: #faf8fb;
                font-family: 'Segoe UI', sans-serif;
            }

            .wrapper {
                width: 100%;
                padding: 40px 0;
            }

            .main-card {
                max-width: 480px;
                margin: auto;
                background: #fff;
                border-radius: 22px;
                overflow: hidden;
                border: 1px solid rgba(134,96,142,0.08);
                box-shadow: 0 10px 30px rgba(134,96,142,0.05);
            }

            /* HEADER */
            .header-area {
                text-align: center;
                padding: 30px 30px 20px;
                background: linear-gradient( 180deg, rgba(134,96,142,0.03) 0%, rgba(255,255,255,1) 100% );
            }

            .logo {
                width: 150px;
                max-width: 100%;
                margin-bottom: 10px;
                display: block;
                margin-left: auto;
                margin-right: auto;
            }

            .system-title {
                color: #86608E;
                font-size: 14px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 1px;
            }

            .security-badge {
                display: inline-block;
                margin-top: 10px;
                background: #f3edf5;
                color: #86608E;
                padding: 6px 12px;
                border-radius: 30px;
                font-size: 10px;
                font-weight: 600;
            }

            /* BODY */
            .content-body {
                text-align: center;
                padding: 40px 30px;
            }

            h1 {
                margin: 0 0 10px;
                font-size: 24px;
                color: #1a0f1f;
            }

            .subtitle {
                color: #666;
                font-size: 14px;
                line-height: 1.6;
                margin-bottom: 30px;
            }

            /* OTP */
            .otp-box {
                display: inline-block;
                background: linear-gradient(180deg,#fff 0%,#fbf9fc 100%);
                border: 1px solid rgba(134,96,142,0.25);
                border-radius: 16px;
                padding: 14px 24px;
                font-size: 30px;
                font-weight: 700;
                color: #86608E;
                letter-spacing: 6px;
                margin-bottom: 25px;
            }

            /* LOGIN BUTTON */
            .login-btn {
                display: inline-block;
                margin-top: 10px;
                background: #86608E;
                color: #fff !important;
                text-decoration: none;
                padding: 12px 26px;
                border-radius: 10px;
                font-size: 14px;
                font-weight: 600;
            }

                .login-btn:hover {
                    background: #75507d;
                }

            /* FOOTER */
            .footer {
                text-align: center;
                padding: 18px;
                font-size: 12px;
                color: #999;
                border-top: 1px solid #f5eff6;
                background: #faf8fb;
            }

            /* MOBILE */
            @@media only screen and (max-width:520px) {

                .main-card {
                    margin: 0 12px;
                }

                .content-body {
                    padding: 35px 20px;
                }

                .otp-box {
                    font-size: 26px;
                    padding: 12px 20px;
                    letter-spacing: 5px;
                }

                h1 {
                    font-size: 20px;
                }
            }

    </style>

</head>

<body>

    <div class="wrapper">

        <div class="main-card">

            <!-- HEADER -->
            <div class="header-area">

                <img src="@Model.LogoUrl"
                     alt="Tanker Management System Logo"
                     class="logo" />

                <div class="system-title">
                    Tanker Management System
                </div>

                <div class="security-badge">
                    Secure Verification
                </div>

            </div>

            <!-- BODY -->
            <div class="content-body">

                <h1>OTP Verification</h1>

                <p class="subtitle">
                    Use the verification code below to continue.
                </p>

                <div class="otp-box">
                    @Model.OtpCode
                </div>

                <br />

                <a href="https://localhost:7104/Admin/Login"
                   class="login-btn">
                    Login Now
                </a>

            </div>

            <!-- FOOTER -->
            <div class="footer">
                © 2026 Tanker Management System
            </div>

        </div>

    </div>

</body>
</html>