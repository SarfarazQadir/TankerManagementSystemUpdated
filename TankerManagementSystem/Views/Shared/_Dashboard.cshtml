@using Microsoft.AspNetCore.Identity
@using System.Security.Claims
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@using TankerManagementSystem.Models
@inject TankerManagementSystem.Models.ApplicationDbContext _context
@inject UserManager<IdentityUser> UserManager

@{
    IdentityUser user = null;
    if (User?.Identity?.IsAuthenticated == true)
    {
        user = await UserManager.GetUserAsync(User);

        // Fallback: if GetUserAsync didn't find the user, try by NameIdentifier claim
        if (user == null)
        {
            var userId1 = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (!string.IsNullOrEmpty(userId1))
            {
                user = await UserManager.FindByIdAsync(userId1);
            }
        }
    }

    // Choose a display name with fallbacks
    string name = user?.UserName ?? User?.Identity?.Name ?? "User";

    // Default profile image
    string profileImage = Url.Content("~/img/user.png");

    // 1. User ki ID aur Admin status nikalna
    var userId = User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? User.FindFirst(ClaimTypes.Name)?.Value;
    var isAdmin = User.IsInRole("Admin");

    // 2. Agar user Admin NAHI hai, toh uske saare allowed modules pehle hi memory me load kar lein (Performance ke liye)
    var allowedModules = new List<string>();
    if (!isAdmin && !string.IsNullOrEmpty(userId))
    {
        allowedModules = _context.UserPermissions
            .Include(up => up.Module)
            .Where(up => (up.UserId == userId || up.User.UserName == userId) && up.CanView)
            .Select(up => up.Module.Controller.ToLower())
            .ToList();
    }

    // Helper function taake baar baar code na likhna pare
    bool HasAccess(string controllerName)
    {
        if (isAdmin) return true; // Admin ko sab ka access hai
        return allowedModules.Contains(controllerName.ToLower()); // Baqi users ke liye DB check
    }
}

