                        + (item.AmountPay ?? 0)
                        + expense;

                        decimal net =
                        item.Freight - deduction;

                        <tr>

                            <td>@i</td>

                            <td>
                                @item.TripDate.ToString("dd MMM yyyy")
                            </td>

                            <td>
                                @item.TripEntryFk?.FromLocation
                                →
                                @item.TripEntryFk?.ToLocation
                            </td>

                            <td>
                                @item.Product?.ProductName
                            </td>

                            <td class="text-right">
                                @Math.Floor(item.Freight)
                            </td>

                            <td class="text-right expense">
                                - @Math.Floor(deduction)
                            </td>

                            <td class="text-right @(net >= 0 ? "profit" : "loss")">

                                @Math.Floor(net)

                            </td>

                        </tr>

                        i++;
                    }

                </tbody>

            </table>

            <!-- SUMMARY -->

            <div class="summary-grid">

                <div class="notes">

                    <h3 style="color:#86608E">
                        Notes
                    </h3>

                    <p>
                        This monthly statement contains all tanker
                        trips, freight details, deductions,
                        shortages, expenses and net balances for the
                        selected month.
                    </p>

                    <br />
                    <br />

                    <p>

                        __________________________

                        <br />

                        Authorised Signature

                    </p>

                </div>

                <div>

                    <table class="summary-table">

                        <tr>
                            <td>Total Freight</td>
                            <td class="text-right">
                                @Math.Floor(totalFreight)
                            </td>
                        </tr>

                        <tr>
                            <td class="expense">
                                Advance Cash
                            </td>

                            <td class="text-right expense">
                                - @Math.Floor(totalAdvance)
                            </td>
                        </tr>

                        <tr>
                            <td class="expense">
                                Shortage
                            </td>

                            <td class="text-right expense">
                                - @Math.Floor(totalShortage)
                            </td>
                        </tr>

                        <tr>
                            <td class="expense">
                                Commission
                            </td>

                            <td class="text-right expense">
                                - @Math.Floor(totalCommission)
                            </td>
                        </tr>

                        <tr>
                            <td class="expense">
                                Munshiana
                            </td>

                            <td class="text-right expense">
                                - @Math.Floor(totalMunshiana)
                            </td>
                        </tr>

                        <tr>
                            <td class="expense">
                                Expenses
                            </td>

                            <td class="text-right expense">
                                - @Math.Floor(totalExpense)
                            </td>
                        </tr>

                        <tr>
                            <td class="expense">
                                Paid Amount
                            </td>

                            <td class="text-right expense">
                                 @Math.Floor(totalPaid)
                            </td>
                        </tr>

                        <tr>
                            <td>
                                Total Deductions
                            </td>

                            <td class="text-right">
                                @Math.Floor(totalDeduction)
                            </td>
                        </tr>

                        <tr class="grand-row">

                            <td>
                                FINAL BALANCE
                            </td>

                            <td class="text-right">

                                @Math.Floor(grandNet)

                            </td>

                        </tr>

                    </table>

                </div>

            </div>

        </div>

        <div class="footer-line"></div>

    </div>

</body>

</html>