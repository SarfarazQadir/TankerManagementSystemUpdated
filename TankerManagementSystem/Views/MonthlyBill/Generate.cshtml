                </p>

            </div>

            <div class="info-box">

                <h2>Statement Details</h2>

                <p>
                    <strong>Total Trips:</strong>
                    @Model.Count()
                </p>

                <p>
                    <strong>Statement Month:</strong>
                    @monthName
