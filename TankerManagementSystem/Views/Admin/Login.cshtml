@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin Login</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/css/app.min.css" />

    <!-- Theme CSS -->
    <link rel="stylesheet" href="~/css/style.css" />
    <link rel="stylesheet" href="~/css/components.css" />
    <link rel="stylesheet" href="~/css/custom.css" />
    <link rel="stylesheet" href="~/css/site.css" />

    <!-- Font Awesome -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />

    <!-- SweetAlert -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@10"></script>

    <link rel="shortcut icon" href="~/img/flyeasy.png" />

    <style>

        body {
        background: linear-gradient(rgba(134,96,142,0.08), rgba(134,96,142,0.08)), #f4f6f9;
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        font-family: 'Segoe UI';
        padding: 20px;
        }

        /* =========================
        LOADER
        ==========================*/

        .loader-wrapper {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(255,255,255,0.85);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 99999;
        }

        .loader {
        border: 5px solid #f3f3f3;
        border-top: 5px solid #86608E;
        border-radius: 50%;
        width: 55px;
        height: 55px;
        animation: spin .7s linear infinite;
        }

        @@keyframes spin {
        100% {
        transform: rotate(360deg);
        }
        }

        .d-none {
        display: none !important;
        }

        /* =========================
        LOGIN CARD
        ==========================*/

        .login-container {
        width: 100%;
        max-width: 430px;
        background: rgba(255,255,255,0.92);
        backdrop-filter: blur(10px);
        border-radius: 24px;
        padding: 45px 35px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.08), 0 2px 10px rgba(134,96,142,0.08);
        border: 1px solid rgba(255,255,255,0.4);
        animation: fadeUp .5s ease;
        }

        @@keyframes fadeUp {
        from {
        opacity: 0;
        transform: translateY(25px);
        }

        to {
        opacity: 1;
        transform: translateY(0);
        }
        }

        .login-logo {
        text-align: center;
        margin-bottom: 20px;
        }

        .login-logo img {
        width: 155px;
        transition: .3s;
        }

        .login-logo img:hover {
        transform: scale(1.03);
        }

        .login-subtitle {
        text-align: center;
        color: #666;
        margin-bottom: 30px;
        font-size: 15px;
        }

        /* =========================
        FORM
        ==========================*/

        .form-group {
        margin-bottom: 24px;
        position: relative;
        }

        .form-group label {
        font-weight: 600;
        margin-bottom: 8px;
        display: block;
        color: #333;
        }

        .form-control {
        height: 52px;
        border-radius: 12px;
        border: 1px solid #ddd;
        padding-left: 15px;
        padding-right: 45px;
        transition: .3s;
        font-size: 15px;
        }

        .form-control:focus {
        border-color: #86608E;
        box-shadow: 0 0 0 4px rgba(134,96,142,0.12);
        }

        .form-group i {
        position: absolute;
        right: 16px;
        top: 46px;
        color: #999;
        }

        .toggle-password {
        cursor: pointer;
        }

        /* =========================
        BUTTON
        ==========================*/

        .btn-primary {
        width: 100%;
        height: 52px;
        border: none;
        border-radius: 12px;
        font-size: 16px;
        font-weight: 600;
        background: linear-gradient(135deg,#86608E,#75507d) !important;
        transition: .3s;
        letter-spacing: .3px;
        }

        .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(134,96,142,0.3);
        }

        /* =========================
        OTP MODAL
        ==========================*/

        .otp-modal-dialog {
        max-width: 430px;
        }

        .otp-modal-content {
        border: none;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 10px 35px rgba(0,0,0,0.15);
        position: relative;
        }

        .modal-body {
        padding: 35px 28px;
        background: white;
        }

        .otp-card {
        background: #f8f8f8;
        border-radius: 18px;
        padding: 30px 24px;
        }

        /* =========================
        CLOSE BTN
        ==========================*/

        #otpCancelBtn {
        background: #86608E;
        color: white;
        width: 34px;
        height: 34px;
        border-radius: 50%;
        border: none;
        position: absolute;
        top: 12px;
        right: 12px;
        z-index: 99;
        font-size: 22px;
        transition: .3s;
        }

        #otpCancelBtn:hover {
        transform: rotate(90deg);
        background: #75507d;
        }

        #otpCancelBtn:focus {
        outline: none;
        box-shadow: none;
        }

        /* =========================
        OTP ICON
        ==========================*/

        .otp-icon-wrapper {
        width: 85px;
        height: 85px;
        background: rgba(134,96,142,.12);
        border-radius: 50%;
        margin: auto;
        display: flex;
        justify-content: center;
        align-items: center;
        }

        .otp-icon-wrapper i {
        font-size: 38px;
        color: #86608E;
        }

        /* =========================
        OTP TEXT
        ==========================*/

        .otp-title {
        font-size: 28px;
        font-weight: 700;
        color: #222;
        margin-bottom: 10px;
        }

        .otp-subtitle {
        color: #666;
        font-size: 15px;
        }

        /* =========================
        OTP BOXES
        ==========================*/

        .otp-inputs-wrapper {
        display: flex;
        justify-content: center;
        gap: 10px;
        }

        .otp-box {
        width: 50px;
        height: 58px;
        border-radius: 12px;
        border: 2px solid #ddd;
        background: white;
        text-align: center;
        font-size: 24px;
        font-weight: 700;
        color: #333;
        transition: .3s;
        }

        .otp-box:focus {
        border-color: #86608E;
        box-shadow: 0 0 10px rgba(134,96,142,0.2);
        outline: none;
        transform: translateY(-2px);
        }

        .otp-box.active {
        border-color: #86608E;
        background: rgba(134,96,142,0.05);
        }

        /* =========================
        TIMER
        ==========================*/

        .timer-section {
        text-align: center;
        }

        .timer-text {
        color: #666;
        font-size: 14px;
        margin-bottom: 8px;
        }

        .timer-count {
        color: #86608E;
        font-weight: 700;
        }

        .btn-resend {
        border: none;
        background: transparent;
        color: #86608E;
        font-weight: 600;
        text-decoration: underline;
        }

        .btn-resend:disabled {
        color: #bbb;
        text-decoration: none;
        cursor: not-allowed;
        }

        /* =========================
        OTP BUTTONS
        ==========================*/

        .otp-btn-group {
        display: flex;
        justify-content: center;
        gap: 12px;
        }

        .otp-cancel-btn {
        background: #e5e5e5;
        color: #333;
        border-radius: 10px;
        padding: 10px 25px;
        border: none;
        font-weight: 600;
        }

        .otp-verify-btn {
        background: #86608E;
        color: white;
        border-radius: 10px;
        padding: 10px 28px;
        border: none;
        font-weight: 600;
        transition: .3s;
        }

        .otp-verify-btn:hover {
        background: #75507d;
        transform: translateY(-1px);
        }

        /* =========================
        SHAKE
        ==========================*/

        .shake {
        animation: shake .35s linear;
        }

        @@keyframes shake {

        0% {
        transform: translateX(0);
        }

        25% {
        transform: translateX(6px);
        }

        50% {
        transform: translateX(-6px);
        }

        75% {
        transform: translateX(6px);
        }

        100% {
        transform: translateX(0);
        }
        }

        /* =========================
        LOADING BTN
        ==========================*/

        .otp-verify-btn.loading {
        pointer-events: none;
        opacity: .8;
        }

        .otp-verify-btn.loading::after {
        content: "";
        width: 16px;
        height: 16px;
        border: 2px solid rgba(255,255,255,.5);
        border-top-color: white;
        border-radius: 50%;
        display: inline-block;
        margin-left: 10px;
        animation: spin .6s linear infinite;
        }

        /* =========================
        RESPONSIVE
        ==========================*/

        @@media(max-width:576px) {

        .login-container {
        padding: 35px 20px;
        border-radius: 20px;
        }

        .otp-box {
        width: 40px;
        height: 50px;
        font-size: 20px;
        }

        .otp-inputs-wrapper {
        gap: 8px;
        }

        .otp-title {
        font-size: 24px;
        }
        }

    </style>

</head>

<body>

    <!-- LOADER -->
    <div id="pageLoader" class="loader-wrapper d-none">
        <div class="loader"></div>
    </div>

    <!-- TEMP ALERTS -->
    @{
        if (TempData["login_failed_message"] != null)
        {
            <script>
                Swal.fire({
                title: '@TempData["login_failed_message"]',
                text: 'Please try again',
                icon: 'error'
                });
            </script>
        }

        if (TempData["logout_message"] != null)
        {
            <script>
                Swal.fire({
                title: '@TempData["logout_message"]',
                text: 'You have been logged out',
                icon: 'success'
                });
            </script>
        }
    }

    <!-- LOGIN CARD -->
    <div class="login-container">

        <div class="login-logo">
            <img src="~/img/flyeasy.png" alt="Logo" />
        </div>

        <div class="login-subtitle">
            Login to manage your account & bills
        </div>

        <form id="loginForm" novalidate>

            <!-- USERNAME -->
            <div class="form-group">
                <label>Username</label>

                <input type="text"
                       name="username"
                       id="username"
                       class="form-control"
                       placeholder="Enter your username"
                       required />

                <i class="fas fa-user"></i>
            </div>

            <!-- PASSWORD -->
            <div class="form-group">

                <label>Password</label>

                <input type="password"
                       id="password"
                       name="password"
                       class="form-control"
                       placeholder="Enter your password"
                       required />

                <i class="fas fa-eye toggle-password"
                   id="togglePassword"></i>

            </div>

            <!-- REMEMBER -->
            <div class="form-group d-flex justify-content-between align-items-center">

                <div class="custom-control custom-checkbox">

                    <input type="checkbox"
                           class="custom-control-input"
                           id="remember">

                    <label class="custom-control-label"
                           for="remember">
                        Remember Me
                    </label>

                </div>

            </div>

            <!-- LOGIN BTN -->
            <div class="form-group">
                <button type="submit"
                        class="btn btn-primary text-white">
                    Login
                </button>
            </div>

        </form>

    </div>

    <!-- OTP MODAL -->
    <div class="modal fade"
         id="otpModal"
         data-backdrop="static"
         data-keyboard="false"
         tabindex="-1"
         role="dialog"
         aria-hidden="true">

        <div class="modal-dialog modal-dialog-centered otp-modal-dialog">

            <div class="modal-content otp-modal-content">

                <!-- CLOSE -->
           @*      <button type="button"
                        id="otpCancelBtn"
                        class="close"
                        data-dismiss="modal">

                    <span>&times;</span>

                </button> *@

                <div class="modal-body">

                    <div class="otp-card text-center">

                        <!-- LOGO --> 
                        <div class="otp-icon-wrapper mb-3"> <img src="~/img/flyeasy.png" alt="FlyEasy Logo" class="otp-logo-img" /> </div>
                        <style> 
                            .otp-logo-img {
                            width: 60px;
                            height: 60px;
                            object-fit: contain;
                            }
                        </style>
                        <!-- TITLE -->
                        <h3 class="otp-title">
                            OTP Verification
                        </h3>

                        <p class="otp-subtitle">
                            Enter the 6-digit security code sent to your email
                        </p>

                        <!-- OTP BOXES -->
                        <div class="otp-inputs-wrapper mt-4 mb-3">

                            <input type="text" class="otp-box" maxlength="1" inputmode="numeric" />
                            <input type="text" class="otp-box" maxlength="1" inputmode="numeric" />
                            <input type="text" class="otp-box" maxlength="1" inputmode="numeric" />
                            <input type="text" class="otp-box" maxlength="1" inputmode="numeric" />
                            <input type="text" class="otp-box" maxlength="1" inputmode="numeric" />
                            <input type="text" class="otp-box" maxlength="1" inputmode="numeric" />

                        </div>

                        <!-- ERROR -->
                        <small id="otpError"
                               class="text-danger d-none">
                            Invalid OTP
                        </small>

                        <!-- TIMER -->
                        <div class="timer-section mt-3">

                            <div class="timer-text">
                                Code expires in
                                <span id="countdown"
                                      class="timer-count">
                                    01:00
                                </span>
                            </div>

                            <button type="button"
                                    id="resendOtpBtn"
                                    class="btn-resend"
                                    disabled>
                                Resend OTP
                            </button>

                        </div>

                        <!-- BUTTONS -->
                        <div class="otp-btn-group mt-4">

                            <button type="button"
                                    class="btn otp-cancel-btn"
                                    data-dismiss="modal">
                                Cancel
                            </button>

                            <button type="button"
                                    id="verifyOtpBtn"
                                    class="btn otp-verify-btn">
                                Verify OTP
                            </button>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <!-- SCRIPTS -->
    <script src="~/js/app.min.js"></script>
    <script src="~/js/scripts.js"></script>
    <script src="~/js/custom.js"></script>

    <script>

        let currentUsername = "";
        let countdownTimer;
        let timeLeft = 60;
        let isOtpExpired = false;

        const loader = document.getElementById("pageLoader");

        function showLoader() {
        loader.classList.remove("d-none");
        }

        function hideLoader() {
        loader.classList.add("d-none");
        }

        /* =========================
        PASSWORD TOGGLE
        ==========================*/

        document.getElementById("togglePassword")
        .addEventListener("click", function () {

        const passwordInput =
        document.getElementById("password");

        const type =
        passwordInput.getAttribute("type") === "password"
        ? "text"
        : "password";

        passwordInput.setAttribute("type", type);

        this.classList.toggle("fa-eye");
        this.classList.toggle("fa-eye-slash");

        });

        /* =========================
        OTP INPUTS
        ==========================*/

        const otpBoxes =
        document.querySelectorAll('.otp-box');

        otpBoxes.forEach((box, index) => {

        // INPUT
        box.addEventListener('input', () => {

        box.value =
        box.value.replace(/[^0-9]/g, '');

        if (box.value.length === 1 &&
        index < otpBoxes.length - 1) {

        otpBoxes[index + 1].focus();
        }

        toggleActive(box);

        const otp = getOtpValue();

        if (otp.length === 6) {
        document.getElementById("verifyOtpBtn").focus();
        }

        });

        // KEYDOWN
        box.addEventListener('keydown', (e) => {

        if (e.key === "Backspace" &&
        !box.value &&
        index > 0) {

        otpBoxes[index - 1].focus();
        }

        if (e.key === "Enter") {
        document.getElementById("verifyOtpBtn").click();
        }

        });

        // FOCUS
        box.addEventListener('focus', () => {
        box.classList.add('active');
        });

        box.addEventListener('blur', () => {
        box.classList.remove('active');
        });

        });

        // PASTE FULL OTP
        otpBoxes[0].addEventListener('paste', (e) => {

        const pastedData =
        (e.clipboardData || window.clipboardData)
        .getData('text')
        .replace(/\D/g, '');

        if (pastedData.length === 6) {

        otpBoxes.forEach((box, i) => {
        box.value = pastedData[i] || '';
        });

        document.getElementById("verifyOtpBtn").focus();
        }

        e.preventDefault();

        });

        function toggleActive(box) {

        if (box.value) {
        box.classList.add('active');
        }
        else {
        box.classList.remove('active');
        }
        }

        function getOtpValue() {

        let code = "";

        otpBoxes.forEach(box => code += box.value);

        return code;
        }

        /* =========================
        TIMER
        ==========================*/

        function startTimer() {

        clearInterval(countdownTimer);

        timeLeft = 60;
        isOtpExpired = false;

        document.getElementById("resendOtpBtn").disabled = true;

        document.getElementById("otpError")
        .classList.add("d-none");

        document.querySelectorAll('.otp-box')
        .forEach(box => box.value = '');

        otpBoxes[0].focus();

        countdownTimer = setInterval(function () {

        timeLeft--;

        let minutes = Math.floor(timeLeft / 60);
        let seconds = timeLeft % 60;

        document.getElementById("countdown")
        .textContent =
        (minutes < 10 ? "0" : "") +
        minutes +
        ":" +
        (seconds < 10 ? "0" : "") +
        seconds;

        if (timeLeft <= 0) {

        clearInterval(countdownTimer);

        isOtpExpired = true;

        document.getElementById("otpError")
        .textContent =
        "OTP expired. Please resend.";

        document.getElementById("otpError")
        .classList.remove("d-none");

        document.getElementById("resendOtpBtn")
        .disabled = false;
        }

        }, 1000);
        }

        /* =========================
        LOGIN FORM
        ==========================*/

        document.addEventListener("DOMContentLoaded", function () {

        const usernameInput =
        document.getElementById("username");

        const passwordInput =
        document.getElementById("password");

        const rememberCheckbox =
        document.getElementById("remember");

        // REMEMBER
        if (localStorage.getItem("rememberMe") === "true") {

        usernameInput.value =
        localStorage.getItem("savedUsername") || "";

        passwordInput.value =
        localStorage.getItem("savedPassword") || "";

        rememberCheckbox.checked = true;
        }

        // LOGIN SUBMIT
        document.getElementById("loginForm")
        .addEventListener("submit", async function (e) {

        e.preventDefault();

        const username =
        usernameInput.value.trim();

        const password =
        passwordInput.value.trim();

        if (username === "" || password === "") {

        Swal.fire({
        icon: 'error',
        title: 'Validation Error',
        text: 'Username and Password are required'
        });

        return;
        }

        showLoader();

        try {

        const response =
        await fetch('/api/Authentication/login', {

        method: 'POST',

        headers: {
        'Content-Type': 'application/json'
        },

        body: JSON.stringify({
        username: username,
        password: password
        })

        });

        const data = await response.json();

        hideLoader();

        if (response.ok) {

        currentUsername = username;

        if (rememberCheckbox.checked) {

        localStorage.setItem(
        "savedUsername",
        username);

        localStorage.setItem(
        "savedPassword",
        password);

        localStorage.setItem(
        "rememberMe",
        "true");
        }
        else {

        localStorage.removeItem("savedUsername");
        localStorage.removeItem("savedPassword");

        localStorage.setItem(
        "rememberMe",
        "false");
        }

        $('#otpModal').modal('show');

        startTimer();
        }
        else {

        Swal.fire({
        icon: 'error',
        title: 'Login Failed',
        text: data.message ||
        'Invalid credentials'
        });

        }

        }
        catch (error) {

        hideLoader();

        Swal.fire({
        icon: 'error',
        title: 'Server Error',
        text: 'Something went wrong'
        });

        }

        });

        });

        /* =========================
        VERIFY OTP
        ==========================*/

        document.getElementById("verifyOtpBtn")
        .addEventListener("click", async function () {

        const otp = getOtpValue();

        if (otp.length < 6) {

        document.getElementById("otpError")
        .textContent =
        "Please enter all 6 digits.";

        document.getElementById("otpError")
        .classList.remove("d-none");

        return;
        }

        if (isOtpExpired) {

        document.getElementById("otpError")
        .textContent =
        "OTP expired. Please resend.";

        document.getElementById("otpError")
        .classList.remove("d-none");

        return;
        }

        showLoader();

        const verifyBtn =
        document.getElementById("verifyOtpBtn");

        verifyBtn.classList.add("loading");

        try {

        const response =
        await fetch(`/api/Authentication/login-2FA?code=${otp}&username=${currentUsername}`, {
        method: 'POST'
        });

        const data = await response.json();

        hideLoader();

        verifyBtn.classList.remove("loading");

        if (response.ok) {

        clearInterval(countdownTimer);

        localStorage.setItem(
        "jwtToken",
        data.token);

        Swal.fire({
        icon: 'success',
        title: 'Login Successful',
        text: 'Redirecting...',
        showConfirmButton: false,
        timer: 1500
        });

        const targetUrl =
        data.redirectTo
        ? data.redirectTo
        : '/Admin/Index';

        setTimeout(() => {
        window.location.href = targetUrl;
        }, 1500);

        }
        else {

        document.getElementById("otpError")
        .textContent =
        data.message || "Invalid OTP";

        document.getElementById("otpError")
        .classList.remove("d-none");

        document.querySelector(".otp-inputs-wrapper")
        .classList.add("shake");

        setTimeout(() => {

        document.querySelector(".otp-inputs-wrapper")
        .classList.remove("shake");

        }, 400);
        }

        }
        catch (error) {

        hideLoader();

        verifyBtn.classList.remove("loading");

        Swal.fire({
        icon: 'error',
        title: 'Server Error',
        text: 'Something went wrong'
        });

        }

        });

        /* =========================
        RESEND OTP
        ==========================*/

        document.getElementById("resendOtpBtn")
        .addEventListener("click", async function () {

        showLoader();

        try {

        const response =
        await fetch('/api/Authentication/login', {

        method: 'POST',

        headers: {
        'Content-Type': 'application/json'
        },

        body: JSON.stringify({
        username:
        document.getElementById("username")
        .value.trim(),

        password:
        document.getElementById("password")
        .value.trim()
        })

        });

        hideLoader();

        if (response.ok) {

        startTimer();

        Swal.fire({
        icon: 'success',
        title: 'OTP Sent Again',
        timer: 1200,
        showConfirmButton: false
        });

        }
        else {

        Swal.fire({
        icon: 'error',
        title: 'Failed',
        text: 'Could not resend OTP'
        });

        }

        }
        catch (error) {

        hideLoader();

        Swal.fire({
        icon: 'error',
        title: 'Server Error',
        text: 'Connection failed.'
        });

        }

        });

    </script>

</body>
</html>